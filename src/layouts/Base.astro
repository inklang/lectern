---
import { createServerClient, parseCookieHeader } from '@supabase/ssr'

interface Props {
  title: string
  description?: string
  ogTitle?: string
  ogDescription?: string
  ogImage?: string
  ogUrl?: string
  ogImagePath?: string // if set, generates og:image URL from this path
}
const {
  title,
  description = 'The Ink package registry',
  ogTitle,
  ogDescription,
  ogImage,
  ogUrl,
  ogImagePath,
} = Astro.props

const resolvedOgImage = ogImage ?? (ogImagePath ? `https://lectern.inklang.org/api/og/${encodeURIComponent(ogImagePath)}` : undefined)

const supabase = createServerClient(
  import.meta.env.SUPABASE_URL ?? '',
  import.meta.env.SUPABASE_PUBLISHABLE_KEY ?? '',
  {
    cookies: {
      getAll() {
        return parseCookieHeader(Astro.request.headers.get('Cookie') ?? '')
      },
      setAll() {},
    },
  }
)

const { data: { session } } = await supabase.auth.getSession()
const avatar = session?.user.user_metadata?.avatar_url ?? null
const username = session?.user.user_metadata?.user_name ?? null
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} — Lectern</title>

  <!-- Open Graph / Discord Rich Embeds -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={ogTitle ?? `${title} — Lectern`} />
  <meta property="og:description" content={ogDescription ?? description} />
  {ogUrl && <meta property="og:url" content={ogUrl} />}
  {resolvedOgImage && <meta property="og:image" content={resolvedOgImage} />}
  <meta property="og:site_name" content="Lectern" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={ogTitle ?? `${title} — Lectern`} />
  <meta name="twitter:description" content={ogDescription ?? description} />
  {resolvedOgImage && <meta name="twitter:image" content={resolvedOgImage} />}

  <link rel="alternate" type="application/atom+xml" title="Lectern Feed" href="/api/feed.xml" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #09090b;
      --surface: #18181b;
      --border: #3f3f46;
      --text: #fafafa;
      --muted: #a1a1aa;
      --muted-2: #71717a;
      --accent: #8b5cf6;
      --font-mono: ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, monospace;
      --font-sans: ui-sans-serif, system-ui, -apple-system, sans-serif;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font-sans);
      font-size: 0.9375rem;
      line-height: 1.6;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      -webkit-font-smoothing: antialiased;
    }

    header {
      border-bottom: 1px solid var(--border);
      padding: 0 2rem;
      height: 3.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      background: var(--bg);
      z-index: 10;
    }

    .header-left {
      display: flex;
      align-items: center;
      gap: 1.5rem;
    }

    header a.wordmark {
      font-family: var(--font-mono);
      font-size: 1rem;
      font-weight: 600;
      color: var(--text);
      text-decoration: none;
      letter-spacing: -0.02em;
    }

    header nav {
      display: flex;
      gap: 0.25rem;
    }

    header nav a {
      font-size: 0.875rem;
      color: var(--muted);
      text-decoration: none;
      padding: 0.25rem 0.75rem;
      border-radius: 6px;
      transition: color 0.15s, background 0.15s;
      letter-spacing: 0.01em;
    }

    header nav a:hover {
      color: var(--text);
      background: var(--surface);
    }

    .header-right {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .nav-login {
      font-size: 0.8125rem;
      padding: 0.35rem 0.875rem;
      border-radius: 8px;
      border: 1px solid var(--border);
      background: transparent;
      color: var(--text);
      text-decoration: none;
      transition: background 0.15s, border-color 0.15s;
    }

    .nav-login:hover {
      background: var(--surface);
      border-color: var(--accent);
      opacity: 1;
    }

    .nav-avatar {
      display: flex;
      align-items: center;
      text-decoration: none;
      border-radius: 50%;
      border: 2px solid transparent;
      transition: border-color 0.15s;
    }

    .nav-avatar:hover {
      border-color: var(--accent);
      opacity: 1;
    }

    .nav-avatar img {
      width: 2rem;
      height: 2rem;
      border-radius: 50%;
      display: block;
    }

    main {
      flex: 1;
      max-width: 860px;
      width: 100%;
      margin: 0 auto;
      padding: 4rem 2rem;
    }

    footer {
      border-top: 1px solid var(--border);
      padding: 1.25rem 2rem;
      font-family: var(--font-mono);
      font-size: 0.75rem;
      color: var(--muted-2);
      text-align: center;
    }

    a { color: var(--text); }
    a:hover { opacity: 0.8; }

    .mono { font-family: var(--font-mono); }
    .muted { color: var(--muted); }
  </style>
</head>
<body>
  <header>
    <div class="header-left">
      <a class="wordmark" href="/">lectern</a>
      <nav>
        <a href="/packages">packages</a>
        <a href="https://inklang.org" target="_blank" rel="noopener">docs</a>
      </nav>
    </div>
    <div class="header-right">
      {session ? (
        <a href="/profile" class="nav-avatar" title={username ?? 'profile'}>
          {avatar
            ? <img src={avatar} alt={username ?? 'avatar'} />
            : <span style="width:2rem;height:2rem;border-radius:50%;background:var(--surface);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:0.75rem;color:var(--muted)">{(username ?? 'U')[0].toUpperCase()}</span>
          }
        </a>
      ) : (
        <a href="/login" class="nav-login">login</a>
      )}
    </div>
  </header>
  <main>
    <slot />
  </main>
  <footer>
    lectern — the ink package registry
  </footer>
</body>
</html>
