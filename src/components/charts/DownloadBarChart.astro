---
interface Props {
  data: { version?: string; referrer?: string; country?: string; count: number; percentage?: number }[]
  type?: 'versions' | 'referrers' | 'geo'
  height?: number
  color?: string
}

const { data, type = 'referrers', height = 300, color = 'var(--accent)' } = Astro.props

// Country code to flag emoji mapping (top download countries)
const countryFlags: Record<string, string> = {
  US: '馃嚭馃嚫', DE: '馃嚛馃嚜', GB: '馃嚞馃嚙', FR: '馃嚝馃嚪', CA: '馃嚚馃嚘',
  AU: '馃嚘馃嚭', JP: '馃嚡馃嚨', NL: '馃嚦馃嚤', SE: '馃嚫馃嚜', CH: '馃嚚馃嚟',
  BR: '馃嚙馃嚪', IN: '馃嚠馃嚦', KR: '馃嚢馃嚪', ES: '馃嚜馃嚫', IT: '馃嚠馃嚬',
  PL: '馃嚨馃嚤', MX: '馃嚥馃嚱', RU: '馃嚪馃嚭', SG: '馃嚫馃嚞', NZ: '馃嚦馃嚳',
  CN: '馃嚚馃嚦', TW: '馃嚬馃嚰', HK: '馃嚟馃嚢', IE: '馃嚠馃嚜', NO: '馃嚦馃嚧',
  DK: '馃嚛馃嚢', FI: '馃嚝馃嚠', BE: '馃嚙馃嚜', AT: '馃嚘馃嚬', PT: '馃嚨馃嚬',
  IL: '馃嚠馃嚤', TR: '馃嚬馃嚪', AR: '馃嚘馃嚪', CL: '馃嚚馃嚤', CO: '馃嚚馃嚧',
  ID: '馃嚠馃嚛', TH: '馃嚬馃嚟', VN: '馃嚮馃嚦', MY: '馃嚥馃嚲', PH: '馃嚨馃嚟',
  AE: '馃嚘馃嚜', SA: '馃嚫馃嚘', EG: '馃嚜馃嚞', NG: '馃嚦馃嚞', KE: '馃嚢馃嚜',
  ZA: '馃嚳馃嚘', XX: '馃實', -- unknown
}

const ROW_HEIGHT = 32
const LABEL_WIDTH = 160
const COUNT_WIDTH = 60
const BAR_MAX_WIDTH = 300
const chartHeight = Math.min(data.length * ROW_HEIGHT + 16, height)

const maxCount = Math.max(1, ...data.map(d => d.count))

function getLabel(item: typeof data[0]): string {
  if (type === 'geo' && item.country) {
    const flag = countryFlags[item.country] ?? '馃實'
    return `${flag} ${item.country}`
  }
  if (type === 'versions' && item.version) {
    return `v${item.version}`
  }
  if (type === 'referrers' && item.referrer) {
    return item.referrer.length > 24 ? item.referrer.slice(0, 21) + '...' : item.referrer
  }
  return 'unknown'
}

function getCountWidth(count: number): number {
  return Math.max(4, (count / maxCount) * BAR_MAX_WIDTH)
}
---

<div class="bar-chart" style={`min-height: ${chartHeight}px;`}>
  <svg
    viewBox={`0 0 ${LABEL_WIDTH + BAR_MAX_WIDTH + COUNT_WIDTH + 24} ${chartHeight}`}
    width="100%"
    height={chartHeight}
    aria-label={`${type} bar chart`}
    role="img"
  >
    {data.map((item, i) => {
      const y = i * ROW_HEIGHT + 8
      const barWidth = getCountWidth(item.count)
      const label = getLabel(item)

      return (
        <g class="bar-row" style={`--delay: ${i * 30}ms`}>
          {/* Label */}
          <text
            x={LABEL_WIDTH - 8}
            y={y + 12}
            text-anchor="end"
            dominant-baseline="middle"
            font-family="var(--font-mono)"
            font-size="11"
            fill="var(--text)"
          >
            {label}
          </text>

          {/* Bar background */}
          <rect
            x={LABEL_WIDTH}
            y={y}
            width={BAR_MAX_WIDTH}
            height={ROW_HEIGHT - 6}
            rx="4"
            fill="var(--border)"
            opacity="0.3"
          />

          {/* Bar fill */}
          <rect
            class="bar-fill"
            x={LABEL_WIDTH}
            y={y}
            width={barWidth}
            height={ROW_HEIGHT - 6}
            rx="4"
            fill={color}
            opacity="0.8"
          >
            <animate
              attributeName="width"
              from="0"
              to={barWidth}
              dur="400ms"
              begin={`${i * 30}ms`}
              fill="freeze"
              calcMode="spline"
              keySplines="0.25 0.1 0.25 1"
            />
          </rect>

          {/* Count label */}
          <text
            x={LABEL_WIDTH + BAR_MAX_WIDTH + 8}
            y={y + 12}
            dominant-baseline="middle"
            font-family="var(--font-mono)"
            font-size="10"
            fill="var(--muted)"
          >
            {item.count.toLocaleString()}
          </text>
        </g>
      )
    })}
  </svg>
</div>

<style>
  .bar-chart {
    width: 100%;
    background: var(--surface);
    border-radius: 10px;
    padding: 0.75rem 1rem;
    overflow: hidden;
  }

  svg {
    display: block;
    overflow: visible;
  }

  .bar-row {
    opacity: 1;
  }

  .bar-fill {
    transition: opacity 0.2s ease;
  }

  .bar-row:hover .bar-fill {
    opacity: 1;
  }
</style>
