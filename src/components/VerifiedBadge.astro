---
// VerifiedBadge - shows a checkmark badge for verified publishers
interface Props {
  size?: 'sm' | 'md' | 'lg'
  showLabel?: boolean
}

const { size = 'md', showLabel = false } = Astro.props

const sizes = {
  sm: { width: 14, height: 14, fontSize: '0.65rem', padding: '0.1rem 0.3rem' },
  md: { width: 16, height: 16, fontSize: '0.75rem', padding: '0.15rem 0.4rem' },
  lg: { width: 18, height: 18, fontSize: '0.8rem', padding: '0.2rem 0.5rem' },
}

const s = sizes[size]
---

<span
  class="verified-badge"
  style={`
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: ${s.padding};
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid #22c55e;
    border-radius: 4px;
    color: #22c55e;
    font-family: var(--font-mono, monospace);
    font-size: ${s.fontSize};
    font-weight: 500;
    vertical-align: middle;
  `}
  title="This package is from a verified publisher"
>
  <svg
    width={s.width}
    height={s.height}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2.5"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <polyline points="20 6 9 17 4 12"></polyline>
  </svg>
  {showLabel && <span>Verified</span>}
</span>

<style>
  .verified-badge {
    cursor: default;
    flex-shrink: 0;
  }

  .verified-badge svg {
    flex-shrink: 0;
  }
</style>
