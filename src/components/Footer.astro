---
import { getLocale, t, LOCALES, LOCALE_LABELS, LOCALE_FLAGS } from '../lib/i18n.ts'

const locale = getLocale(Astro.request)
const year = new Date().getFullYear()

const resourcesLabel = await t(locale, 'footer.resources')
const communityLabel = await t(locale, 'footer.community')
const docsLabel = await t(locale, 'footer.documentation')
const languageLabel = await t(locale, 'footer.language')
---

<footer class="footer">
  <div class="footer-content">
    <div class="footer-section">
      <p class="footer-brand">ink</p>
      <p class="footer-tagline">A compiled scripting language for the modern VM.</p>
      <div class="footer-social">
        <a href="https://github.com/inklang/ink" target="_blank" rel="noopener" aria-label="GitHub">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
        <a href="https://discord.gg/ink" target="_blank" rel="noopener" aria-label="Discord">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03z"/>
          </svg>
        </a>
      </div>
    </div>
    <div class="footer-section">
      <p class="footer-heading">{resourcesLabel}</p>
      <a href="/docs">{docsLabel}</a>
      <a href="/packages">{await t(locale, 'nav.packages')}</a>
      <a href="/blog">{await t(locale, 'nav.blog')}</a>
      <a href="/forum">{await t(locale, 'nav.forum')}</a>
    </div>
    <div class="footer-section">
      <p class="footer-heading">{communityLabel}</p>
      <a href="https://github.com/inklang/ink" target="_blank" rel="noopener">GitHub</a>
      <a href="/activity">Activity</a>
    </div>
    <div class="footer-section">
      <p class="footer-heading">{languageLabel}</p>
      <form class="locale-switcher" id="locale-switcher">
        <select name="lang" aria-label={languageLabel}>
          {LOCALES.map(loc => (
            <option value={loc} selected={loc === locale}>
              {LOCALE_FLAGS[loc]} {LOCALE_LABELS[loc]}
            </option>
          ))}
        </select>
      </form>
    </div>
  </div>
  <div class="footer-bottom">
    <p>ink &copy; {year}</p>
  </div>
</footer>

<script>
  const form = document.getElementById('locale-switcher')
  const select = form?.querySelector('select')
  select?.addEventListener('change', (e) => {
    const lang = (e.target as HTMLSelectElement).value
    const url = new URL(location.href)
    url.searchParams.set('lang', lang)
    document.cookie = `lectern_lang=${lang}; path=/; max-age=31536000`
    location.href = url.toString()
  })
</script>

<style>
  .locale-switcher select {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--muted-2);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    padding: 0.3rem 0.5rem;
    cursor: pointer;
    width: 100%;
  }
  .locale-switcher select:hover {
    border-color: var(--accent);
    color: var(--text);
  }
  .locale-switcher select:focus {
    outline: none;
    border-color: var(--accent);
  }
</style>

<style>
  .footer {
    border-top: 1px solid var(--border);
    padding: 3rem 2rem 1.5rem;
    font-size: 0.875rem;
  }

  .footer-content {
    max-width: 860px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .footer-brand {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }

  .footer-tagline {
    color: var(--muted);
    max-width: 24ch;
    line-height: 1.5;
  }

  .footer-social {
    display: flex;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .footer-social a {
    color: var(--muted-2);
    transition: color 0.15s;
  }

  .footer-social a:hover {
    color: var(--text);
  }

  .footer-heading {
    color: var(--muted);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.75rem;
  }

  .footer-section a {
    display: block;
    color: var(--muted-2);
    text-decoration: none;
    margin-bottom: 0.5rem;
    transition: color 0.15s;
  }

  .footer-section a:hover {
    color: var(--text);
  }

  .footer-bottom {
    max-width: 860px;
    margin: 0 auto;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    color: var(--muted-2);
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  @media (max-width: 640px) {
    .footer-content {
      grid-template-columns: 1fr 1fr;
    }

    .footer-section:first-child {
      grid-column: 1 / -1;
    }
  }
</style>
