---
interface Props {
  name?: string
  value?: number
  readonly?: boolean
}

const { name = 'rating', value = 0, readonly = false } = Astro.props
---

<div class={`star-picker ${readonly ? 'readonly' : ''}`} data-name={name} data-value={value}>
  {[1, 2, 3, 4, 5].map((star) => (
    <button
      type="button"
      class={`star ${star <= value ? 'filled' : ''}`}
      data-value={star}
      aria-label={`Rate ${star} star${star !== 1 ? 's' : ''}`}
      disabled={readonly}
    >
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
      </svg>
    </button>
  ))}
  <input type="hidden" name={name} value={value} />
</div>

<style>
  .star-picker {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }

  .star-picker.readonly {
    pointer-events: none;
  }

  .star {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    color: var(--muted);
    transition: color 0.15s, transform 0.15s;
  }

  .star svg {
    width: 1.5rem;
    height: 1.5rem;
    display: block;
  }

  .star:hover {
    transform: scale(1.1);
  }

  .star.filled {
    color: #f59e0b;
  }

  .star:not(.filled):hover {
    color: #fbbf24;
  }

  .star-picker.readonly .star {
    cursor: default;
  }

  .star-picker.readonly .star:hover {
    transform: none;
  }
</style>

<script>
  document.querySelectorAll('.star-picker:not(.readonly)').forEach((picker) => {
    const stars = picker.querySelectorAll('.star')
    const input = picker.querySelector('input[type="hidden"]') as HTMLInputElement | null

    function setValue(val: number) {
      picker.dataset.value = String(val)
      if (input) input.value = String(val)
      stars.forEach((star) => {
        const starVal = parseInt(star.getAttribute('data-value') ?? '0', 10)
        star.classList.toggle('filled', starVal <= val)
      })
    }

    stars.forEach((star) => {
      star.addEventListener('click', () => {
        const val = parseInt(star.getAttribute('data-value') ?? '0', 10)
        setValue(val)
      })

      star.addEventListener('mouseenter', () => {
        const val = parseInt(star.getAttribute('data-value') ?? '0', 10)
        stars.forEach((s) => {
          const sVal = parseInt(s.getAttribute('data-value') ?? '0', 10)
          s.classList.toggle('filled', sVal <= val)
        })
      })
    })

    picker.addEventListener('mouseleave', () => {
      const current = parseInt(picker.dataset.value ?? '0', 10)
      setValue(current)
    })
  })
</script>
