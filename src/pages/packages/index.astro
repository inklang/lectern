---
import Base from '../../layouts/Base.astro'
import ComparePanel from '../../components/ComparePanel.astro'
import HealthBadge from '../../components/HealthBadge.astro'
import { listAllPackages, listTags, getPackagesByTag, getPopularPackages, listPackagesByStars, getStarCounts, getHealthForPackages } from '../../lib/db.js'
import { createServerClient, parseCookieHeader } from '@supabase/ssr'

const supabase = createServerClient(
  import.meta.env.SUPABASE_URL ?? '',
  import.meta.env.SUPABASE_PUBLISHABLE_KEY ?? '',
  {
    cookies: {
      getAll() {
        return parseCookieHeader(Astro.request.headers.get('Cookie') ?? '')
      },
      setAll() {},
    },
  }
)
const { data: { session } } = await supabase.auth.getSession()
const accessToken = session?.access_token ?? null

const PAGE_SIZE = 20

const selectedTag = Astro.url.searchParams.get('tag') ?? null
const sort = Astro.url.searchParams.get('sort') ?? 'recent'
const page = Math.max(1, parseInt(Astro.url.searchParams.get('page') ?? '1'))

let allPackages: Array<{ name: string; latest: any; versionCount: number }> = []
let popularPackages: Array<{ package_name: string; popularity_score: number; download_count: number; star_count: number; latest_version: string; description: string | null; created_at: string }> = []
let starSortedPackages: Array<{ packageName: string; starCount: number }> = []
let totalCount = 0

if (selectedTag) {
  // Tag-filtered view: fetch packages for this tag
  const pkgs = await getPackagesByTag(selectedTag, 100, 0).catch(() => [])
  // Build the same shape as allPackages
  const { listAllPackages: lap } = await import('../../lib/db.js')
  const allMap = await lap()
  allPackages = pkgs
    .filter(p => allMap[p.package_name])
    .map(p => {
      const versions = allMap[p.package_name]
      const sorted = Object.values(versions).sort((a: any, b: any) =>
        new Date(b.published_at).getTime() - new Date(a.published_at).getTime()
      )
      return { name: p.package_name, latest: sorted[0], versionCount: sorted.length }
    })
    .sort((a, b) =>
      new Date(b.latest.published_at).getTime() - new Date(a.latest.published_at).getTime()
    )
  totalCount = allPackages.length
} else if (sort === 'popular') {
  // Popular sort: use getPopularPackages RPC
  popularPackages = await getPopularPackages(PAGE_SIZE, (page - 1) * PAGE_SIZE).catch(() => [])
  totalCount = popularPackages.length
} else if (sort === 'stars') {
  // Stars sort: use listPackagesByStars
  starSortedPackages = await listPackagesByStars(PAGE_SIZE, (page - 1) * PAGE_SIZE).catch(() => [])
  // Get package details for the star-sorted packages
  const { listAllPackages: lap } = await import('../../lib/db.js')
  const allMap = await lap()
  // Filter to only packages that exist and have stars
  allPackages = starSortedPackages
    .filter(p => allMap[p.packageName])
    .map(p => {
      const versions = allMap[p.packageName]
      const sorted = Object.values(versions).sort((a: any, b: any) =>
        new Date(b.published_at).getTime() - new Date(a.published_at).getTime()
      )
      return { name: p.packageName, latest: sorted[0], versionCount: sorted.length, starCount: p.starCount }
    })
  totalCount = allPackages.length
} else {
  const allPackagesMap = await listAllPackages()
  const entries = Object.entries(allPackagesMap)
  allPackages = entries
    .map(([name, versions]) => {
      const sorted = Object.values(versions).sort((a: any, b: any) =>
        new Date(b.published_at).getTime() - new Date(a.published_at).getTime()
      )
      return { name, latest: sorted[0], versionCount: sorted.length }
    })
    .sort((a, b) =>
      new Date(b.latest.published_at).getTime() - new Date(a.latest.published_at).getTime()
    )
  totalCount = entries.length
}

const totalPages = Math.max(1, Math.ceil(totalCount / PAGE_SIZE))
const clampedPage = Math.min(page, totalPages)
const packages = allPackages.slice((clampedPage - 1) * PAGE_SIZE, clampedPage * PAGE_SIZE)

// Fetch star counts for packages when not using a sort that already includes them
let starCounts: Record<string, number> = {}
if (sort !== 'popular' && sort !== 'stars' && packages.length > 0) {
  starCounts = await getStarCounts(packages.map(p => p.name)).catch(() => {})
}

// Fetch health data for displayed packages
let healthMap: Record<string, { score: number; status: import('../../lib/db.js').HealthStatus } | null> = {}
if (displayPackages.length > 0) {
  const pkgNames = displayPackages.map((p: any) => p.name)
  const healthRecords = await getHealthForPackages(pkgNames).catch(() => {})
  if (healthRecords) {
    for (const [name, health] of Object.entries(healthRecords)) {
      healthMap[name] = health
        ? { score: health.health_score, status: health.health_status }
        : null
    }
  }
}

const displayPackages = sort === 'popular'
  ? popularPackages.map(p => ({
      name: p.package_name,
      latest: { version: p.latest_version, description: p.description, published_at: p.created_at },
      versionCount: 1,
      starCount: p.star_count,
      downloadCount: p.download_count,
      popularityScore: p.popularity_score,
    }))
  : packages.map(p => ({
      ...p,
      starCount: sort === 'stars' ? p.starCount ?? 0 : starCounts[p.name] ?? 0,
      downloadCount: 0,
      popularityScore: 0
    }))

const allTags = await listTags().catch(() => [])

function buildPageUrl(p: number) {
  const params = new URLSearchParams()
  params.set('page', String(p))
  if (sort !== 'recent') params.set('sort', sort)
  if (selectedTag) params.set('tag', selectedTag)
  return `/packages?${params.toString()}`
}
---
<Base title="Packages">
  <style>
    .page-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 2rem;
    }

    .page-header h1 {
      font-family: var(--font-mono);
      font-size: 1.25rem;
      font-weight: 600;
      letter-spacing: -0.02em;
    }

    .count {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: var(--muted);
    }

    .layout {
      display: grid;
      grid-template-columns: 1fr 200px;
      gap: 2.5rem;
      align-items: start;
    }

    @media (max-width: 768px) {
      .layout { grid-template-columns: 1fr; }
    }

    .pkg-list { display: flex; flex-direction: column; }

    .pkg-card {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1rem 1.25rem;
      margin-bottom: 0.5rem;
      text-decoration: none;
      color: var(--text);
      gap: 1rem;
      transition: border-color 0.15s;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
    }

    .pkg-card:hover { border-color: var(--accent); opacity: 1; }

    .pkg-left { display: flex; flex-direction: column; gap: 0.25rem; }

    .pkg-name {
      font-family: var(--font-mono);
      font-size: 0.9375rem;
      font-weight: 500;
    }

    .pkg-versions {
      font-size: 0.8rem;
      color: var(--muted);
    }

    .pkg-description { display: block; font-family: system-ui, sans-serif; font-size: 0.8rem; color: var(--muted); margin-top: 0.2rem; }

    .pkg-right { text-align: right; flex-shrink: 0; }

    .pkg-ver {
      font-family: var(--font-mono);
      font-size: 0.875rem;
      color: var(--text);
    }

    .pkg-date {
      font-family: var(--font-mono);
      font-size: 0.775rem;
      color: var(--muted);
      margin-top: 0.2rem;
    }

    .pkg-stars {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      color: #f59e0b;
      margin-left: 0.5rem;
    }

    .pkg-star-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.2rem;
      padding: 0.2rem 0.5rem;
      border-radius: 4px;
      border: 1px solid var(--border);
      background: transparent;
      color: #f59e0b;
      font-family: var(--font-mono);
      font-size: 0.75rem;
      cursor: pointer;
      transition: border-color 0.15s, background 0.15s;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .pkg-star-btn:hover {
      border-color: #f59e0b;
      background: rgba(245, 158, 11, 0.1);
    }

    .pkg-star-btn.starred {
      border-color: #f59e0b;
      background: rgba(245, 158, 11, 0.1);
    }

    .card-wrap {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      flex: 1;
    }

    .pkg-dl {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      color: var(--muted);
      margin-top: 0.2rem;
    }

    .empty {
      font-family: var(--font-mono);
      font-size: 0.875rem;
      color: var(--muted);
      padding: 3rem 0;
    }

    .pagination {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.25rem;
      margin-top: 2.5rem;
      padding-top: 2rem;
      border-top: 1px solid var(--border);
    }

    .page-btn {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      padding: 0.35rem 0.65rem;
      border-radius: 6px;
      border: 1px solid var(--border);
      background: transparent;
      color: var(--muted);
      text-decoration: none;
      transition: background 0.15s, color 0.15s, border-color 0.15s;
      min-width: 2rem;
      text-align: center;
    }

    .page-btn:hover {
      background: var(--surface);
      color: var(--text);
      opacity: 1;
      border-color: var(--accent);
    }

    .page-btn.active {
      background: var(--accent);
      color: #fff;
      border-color: var(--accent);
    }

    .page-btn.disabled {
      opacity: 0.25;
      pointer-events: none;
    }

    .search-bar { margin-bottom: 1.5rem; }

    .sort-chips {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      margin-bottom: 1rem;
    }
    .sort-chip {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      padding: 0.25rem 0.6rem;
      border-radius: 6px;
      border: 1px solid var(--border);
      color: var(--muted);
      cursor: pointer;
      background: none;
      transition: border-color 0.15s, color 0.15s, background 0.15s;
    }
    .sort-chip:hover {
      border-color: var(--accent);
      color: var(--text);
    }
    .sort-chip.active {
      border-color: var(--accent);
      color: var(--accent);
      background: rgba(139, 92, 246, 0.08);
    }
    .pkg-checkbox-label {
      display: none;
      cursor: pointer;
      flex-shrink: 0;
      margin-right: 0.25rem;
      align-items: center;
    }
    @media (hover: hover) {
      .pkg-card:hover .pkg-checkbox-label { display: flex; }
    }
    @media (hover: none), (max-width: 768px) {
      .pkg-checkbox-label { display: flex; }
    }
    .pkg-checkbox {
      width: 16px;
      height: 16px;
      accent-color: var(--accent);
      cursor: pointer;
    }
    .pkg-card { display: flex; align-items: center; }

    .search-bar input {
      width: 100%;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 0.6rem 1rem;
      font-family: var(--font-mono);
      font-size: 0.875rem;
      color: var(--text);
      outline: none;
    }
    .search-bar input:focus { border-color: var(--accent); }

    .sidebar-heading {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 0.75rem;
    }

    .sidebar-tags {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }

    .tag-link {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.3rem 0.5rem;
      border-radius: 6px;
      border: 1px solid transparent;
      text-decoration: none;
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: var(--muted);
      transition: background 0.15s, color 0.15s, border-color 0.15s;
    }

    .tag-link:hover {
      background: var(--surface);
      color: var(--text);
      opacity: 1;
      border-color: var(--border);
    }

    .tag-link.active {
      color: var(--accent);
      border-color: var(--accent);
      background: var(--surface);
    }

    .tag-count {
      font-size: 0.7rem;
      color: var(--muted);
    }

    .tag-filter-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      margin-bottom: 1rem;
      font-family: var(--font-mono);
      font-size: 0.8rem;
      padding: 0.3rem 0.65rem;
      border-radius: 6px;
      border: 1px solid var(--accent);
      color: var(--accent);
    }

    .tag-filter-remove {
      text-decoration: none;
      color: var(--muted);
      margin-left: 0.25rem;
    }
    .tag-filter-remove:hover { color: var(--text); }

    /* Compare bar */
    .compare-bar {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      background: var(--surface);
      border-top: 1px solid var(--border);
      padding: 0.875rem 2rem;
      display: none;
      align-items: center;
      justify-content: space-between;
      z-index: 150;
      box-shadow: 0 -4px 16px rgba(0, 0, 0, 0.2);
      transform: translateY(100%);
      transition: transform 200ms ease-out;
    }
    .compare-bar.visible { display: flex; transform: translateY(0); }
    .compare-bar-text {
      font-family: var(--font-mono);
      font-size: 0.875rem;
      color: var(--text);
    }
    .compare-bar-actions { display: flex; align-items: center; gap: 0.75rem; }
    .compare-view-btn {
      font-family: var(--font-mono);
      font-size: 0.875rem;
      padding: 0.5rem 1.25rem;
      background: var(--accent);
      color: #fff;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      font-weight: 500;
    }
    .compare-view-btn:hover { opacity: 0.85; }
    .compare-clear-btn {
      font-family: var(--font-mono);
      font-size: 0.875rem;
      padding: 0.5rem 0.75rem;
      background: transparent;
      color: var(--muted);
      border: 1px solid var(--border);
      border-radius: 6px;
      cursor: pointer;
    }
    .compare-clear-btn:hover { color: var(--text); border-color: var(--text); }
  </style>

  <div class="page-header">
    <h1>{sort === 'stars' ? 'Top starred packages' : 'packages'}</h1>
    <span class="count">{totalCount} total</span>
  </div>

  {selectedTag && (
    <div class="tag-filter-badge">
      <span>filtered by: {selectedTag}</span>
      <a class="tag-filter-remove" href="/packages">×</a>
    </div>
  )}

  <div class="sort-chips" id="sort-chips">
    <button class="sort-chip active" data-sort="recent">recent</button>
    <button class="sort-chip" data-sort="popular">popular</button>
    <button class="sort-chip" data-sort="stars">Top starred</button>
  </div>

  <div class="search-bar">
    <input
      id="search-input"
      type="search"
      placeholder="Search packages…"
      autocomplete="off"
    />
  </div>

  <div class="layout">
    <div>
      <div id="pkg-list" class="pkg-list">
        {displayPackages.length === 0
          ? <p class="empty">{selectedTag ? 'no packages with this tag.' : 'no packages published yet.'}</p>
          : <>
              {displayPackages.map(pkg => (
                <label class="pkg-checkbox-label" data-package={pkg.name}>
                  <input type="checkbox" class="pkg-checkbox" value={pkg.name} />
                </label>
                <a class="pkg-card" href={`/${pkg.name}`}>
                  <div class="pkg-left">
                    <span class="pkg-name">{pkg.name}</span>
                    <span class="pkg-versions">{pkg.versionCount} version{pkg.versionCount !== 1 ? 's' : ''}</span>
                    {pkg.latest.description && <span class="pkg-description">{pkg.latest.description}</span>}
                  </div>
                  <div class="pkg-right">
                    <div class="pkg-ver">v{pkg.latest.version}</div>
                    <div class="pkg-date">{new Date(pkg.latest.published_at).toLocaleDateString()}</div>
                    {sort === 'popular' && pkg.downloadCount > 0 && (
                      <div class="pkg-dl">{pkg.downloadCount.toLocaleString()} dl</div>
                    )}
                  </div>
                </a>
                {pkg.starCount > 0 && (
                  <button
                    class="pkg-star-btn"
                    data-package={pkg.name}
                    data-starred="false"
                    title="Star this package"
                  >
                    ★ <span class="pkg-star-count">{pkg.starCount}</span>
                  </button>
                )}
              ))}

              {totalPages > 1 && (
                <nav class="pagination" aria-label="Pagination">
                  <a
                    class={`page-btn${clampedPage === 1 ? ' disabled' : ''}`}
                    href={buildPageUrl(clampedPage - 1)}
                    aria-label="Previous page"
                  >←</a>

                  {Array.from({ length: totalPages }, (_, i) => i + 1).map(p => (
                    <a
                      class={`page-btn${p === clampedPage ? ' active' : ''}`}
                      href={buildPageUrl(p)}
                    >{p}</a>
                  ))}

                  <a
                    class={`page-btn${clampedPage === totalPages ? ' disabled' : ''}`}
                    href={buildPageUrl(clampedPage + 1)}
                    aria-label="Next page"
                  >→</a>
                </nav>
              )}
            </>
        }
      </div>
    </div>

    <aside>
      <p class="sidebar-heading">filter by tag</p>
      <div class="sidebar-tags">
        <a class={`tag-link${!selectedTag ? ' active' : ''}`} href="/packages">all packages</a>
        {allTags.map(t => (
          <a class={`tag-link${selectedTag === t.name ? ' active' : ''}`} href={`/packages?tag=${encodeURIComponent(t.name)}`}>
            <span>{t.name}</span>
            <span class="tag-count">{t.package_count}</span>
          </a>
        ))}
      </div>
    </aside>
  </div>

  <div class="compare-bar" id="compare-bar">
    <span class="compare-bar-text" id="compare-bar-text">Compare (0 packages)</span>
    <div class="compare-bar-actions">
      <button class="compare-view-btn" id="compare-view-btn">View Compare</button>
      <button class="compare-clear-btn" id="compare-clear-btn">×</button>
    </div>
  </div>

  <ComparePanel packages={[]} />

  <script define:vars={{ accessToken }}>
    const input = document.getElementById('search-input') as HTMLInputElement
    const input = document.getElementById('search-input') as HTMLInputElement
    const sortChips = document.getElementById('sort-chips') as HTMLDivElement
    const list = document.getElementById('pkg-list') as HTMLDivElement

    const url = new URL(location.href)
    let activeSort = url.searchParams.get('sort') ?? 'recent'
    let cachedResults: Array<{ name: string; package_slug: string; version: string; description: string | null }> = []

    function esc(s: string): string {
      return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;')
    }

    // ── Sort chip activation ───────────────────────────────────────────────
    function activateSortChip(sort: string) {
      sortChips.querySelectorAll('.sort-chip').forEach(c => c.classList.remove('active'))
      sortChips.querySelector(`[data-sort="${sort}"]`)?.classList.add('active')
    }
    activateSortChip(activeSort)

    // ── Sort chip click: navigate to sorted URL ─────────────────────────
    sortChips.querySelectorAll('.sort-chip').forEach(chip => {
      chip.addEventListener('click', () => {
        const newSort = (chip as HTMLButtonElement).dataset.sort ?? 'recent'
        if (newSort === activeSort) return
        activeSort = newSort
        activateSortChip(newSort)
        const params = new URLSearchParams(location.search)
        params.set('page', '1')
        if (newSort === 'recent') params.delete('sort')
        else params.set('sort', newSort)
        location.href = `/packages?${params.toString()}`
      })
    })

    // ── Compare bar ───────────────────────────────────────────────────────
    const compareBar = document.getElementById('compare-bar') as HTMLDivElement
    const compareBarText = document.getElementById('compare-bar-text') as HTMLSpanElement
    const compareViewBtn = document.getElementById('compare-view-btn') as HTMLButtonElement
    const compareClearBtn = document.getElementById('compare-clear-btn') as HTMLButtonElement

    let selectedPackages = new Set<string>()

    function updateCompareBar() {
      const count = selectedPackages.size
      if (count >= 2) {
        compareBarText.textContent = `Compare (${count} packages)`
        compareBar.classList.add('visible')
      } else {
        compareBar.classList.remove('visible')
      }
    }

    function handleCheckboxChange(e: Event) {
      const cb = e.target as HTMLInputElement
      if (cb.checked) selectedPackages.add(cb.value)
      else selectedPackages.delete(cb.value)
      updateCompareBar()
    }

    document.querySelectorAll('.pkg-checkbox').forEach(cb => {
      cb.addEventListener('change', handleCheckboxChange)
    })

    compareClearBtn.addEventListener('click', () => {
      selectedPackages.clear()
      document.querySelectorAll('.pkg-checkbox').forEach(cb => {
        (cb as HTMLInputElement).checked = false
      })
      updateCompareBar()
    })

    compareViewBtn.addEventListener('click', () => {
      if (selectedPackages.size >= 2) {
        window.dispatchEvent(new CustomEvent('compare:open'))
      }
    })

    // ── Card star buttons ─────────────────────────────────────────────────
    async function handleCardStarClick(btn: HTMLButtonElement) {
      const packageName = btn.dataset.package
      if (!packageName) return

      if (!accessToken) {
        window.location.href = `/login?next=/packages`
        return
      }

      const isStarred = btn.dataset.starred === 'true'
      const countEl = btn.querySelector('.pkg-star-count')
      const currentCount = parseInt(countEl?.textContent ?? '0')

      // Optimistic update
      btn.dataset.starred = String(!isStarred)
      countEl.textContent = String(isStarred ? currentCount - 1 : currentCount + 1)
      if (!isStarred) btn.classList.add('starred')
      else btn.classList.remove('starred')

      try {
        const method = isStarred ? 'DELETE' : 'PUT'
        const res = await fetch(`/api/packages/${encodeURIComponent(packageName)}/star`, {
          method,
          headers: { 'Authorization': `Bearer ${accessToken}` }
        })
        if (!res.ok) {
          // Revert on error
          btn.dataset.starred = String(isStarred)
          countEl.textContent = String(currentCount)
          if (isStarred) btn.classList.add('starred')
          else btn.classList.remove('starred')
        } else {
          const data = await res.json()
          btn.dataset.starred = String(data.starred)
          countEl.textContent = String(data.starCount ?? currentCount)
          if (data.starred) btn.classList.add('starred')
          else btn.classList.remove('starred')
        }
      } catch {
        // Revert on error
        btn.dataset.starred = String(isStarred)
        countEl.textContent = String(currentCount)
        if (isStarred) btn.classList.add('starred')
        else btn.classList.remove('starred')
      }
    }

    document.querySelectorAll('.pkg-star-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault()
        e.stopPropagation()
        handleCardStarClick(btn as HTMLButtonElement)
      })
    })

    // ── Search input ───────────────────────────────────────────────────────
    const initialHtml = list.innerHTML
    let debounce: ReturnType<typeof setTimeout>

    input.addEventListener('input', () => {
      clearTimeout(debounce)
      const q = input.value.trim()

      if (!q) {
        list.innerHTML = initialHtml
        cachedResults = []
        // Re-wire checkboxes on reset
        document.querySelectorAll('.pkg-checkbox').forEach(cb => {
          cb.removeEventListener('change', handleCheckboxChange)
          cb.addEventListener('change', handleCheckboxChange)
        })
        return
      }

      debounce = setTimeout(async () => {
        const res = await fetch(`/api/search?q=${encodeURIComponent(q)}`)
        const results = await res.json() as typeof cachedResults
        cachedResults = results

        if (!results.length) {
          list.innerHTML = `<p class="empty">no results.</p>`
          return
        }

        list.innerHTML = results.map(pkg => {
          const slug = esc(pkg.package_slug)
          const name = esc(pkg.name)
          const desc = pkg.description ? esc(pkg.description) : ''
          const ver = esc(pkg.version)
          return '<label class="pkg-checkbox-label">' +
            '<input type="checkbox" class="pkg-checkbox" value="' + name + '" />' +
          '</label>' +
          '<a class="pkg-card" href="/' + slug + '" style="flex:1;">' +
            '<div class="pkg-left">' +
              '<span class="pkg-name">' + name + '</span>' +
              (pkg.description ? '<span class="pkg-description">' + desc + '</span>' : '') +
            '</div>' +
            '<div class="pkg-right">' +
              '<div class="pkg-ver">v' + ver + '</div>' +
            '</div>' +
          '</a>'
        }).join('')

        // Wire checkboxes on newly rendered cards
        document.querySelectorAll('.pkg-checkbox').forEach(cb => {
          cb.addEventListener('change', handleCheckboxChange)
        })
      }, 300)
    })
  </script>
</Base>
