---
import Base from '../../layouts/Base.astro'
import { PackageStore } from '../../store.js'

const { name } = Astro.params
const store = new PackageStore(process.env['STORAGE_DIR'] ?? './storage')
const index = store.readIndex()
const pkg = index.packages[name!]

if (!pkg) return Astro.redirect('/packages')

const versions = Object.values(pkg).sort((a, b) =>
  new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime()
)
const latest = versions[0]
const owner = index.owners[name!]
---
<Base title={name!} description={`${name} — Ink package`}>
  <style>
    .back {
      font-size: 0.8rem;
      color: var(--muted);
      text-decoration: none;
      display: inline-block;
      margin-bottom: 2rem;
    }

    .back:hover { color: var(--text); opacity: 1; }

    .pkg-header {
      border-bottom: 1px solid var(--border);
      padding-bottom: 1.75rem;
      margin-bottom: 2rem;
    }

    .pkg-name {
      font-family: var(--font-mono);
      font-size: 1.75rem;
      font-weight: 600;
      letter-spacing: -0.04em;
    }

    .pkg-meta-row {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-top: 0.5rem;
      flex-wrap: wrap;
    }

    .badge {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      padding: 0.2rem 0.6rem;
      border-radius: 4px;
      border: 1px solid var(--border);
      color: var(--muted);
    }

    .badge.latest {
      border-color: var(--accent);
      color: var(--accent);
    }

    .section {
      margin-bottom: 2.5rem;
    }

    .section-heading {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 0.875rem;
    }

    .code-block {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      background: var(--surface);
      border: 1px solid var(--border);
      font-family: var(--font-mono);
      font-size: 0.875rem;
      padding: 0.65rem 1rem;
      border-radius: 10px;
      color: var(--text);
    }

    .code-block .prompt { color: var(--muted-2); }

    .versions-list { display: flex; flex-direction: column; }

    .version-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.8rem 0;
      border-bottom: 1px solid var(--border);
      font-family: var(--font-mono);
      font-size: 0.875rem;
    }

    .version-row:last-child { border-bottom: none; }

    .version-left { display: flex; align-items: center; gap: 0.75rem; }

    .version-tag {
      display: inline-block;
      font-size: 0.7rem;
      padding: 0.15rem 0.5rem;
      border-radius: 4px;
      border: 1px solid var(--accent);
      color: var(--accent);
    }

    .version-date { color: var(--muted); font-size: 0.8rem; }

    .deps-list { display: flex; flex-direction: column; gap: 0.5rem; }

    .dep-item {
      font-family: var(--font-mono);
      font-size: 0.875rem;
      display: flex;
      align-items: baseline;
      gap: 0.5rem;
    }

    .dep-name { color: var(--text); text-decoration: none; }
    .dep-name:hover { opacity: 0.7; }
    .dep-range { color: var(--muted); }

    .no-deps {
      font-family: var(--font-mono);
      font-size: 0.875rem;
      color: var(--muted);
    }

    .owner-fp {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: var(--muted);
    }
  </style>

  <a class="back" href="/packages">← packages</a>

  <div class="pkg-header">
    <div class="pkg-name">{name}</div>
    <div class="pkg-meta-row">
      <span class="badge latest">v{latest.version}</span>
      {owner && <span class="owner-fp">by {owner.slice(0, 8)}···</span>}
    </div>
  </div>

  <div class="section">
    <p class="section-heading">install</p>
    <div class="code-block">
      <span class="prompt">$</span>
      <span>quill add {name}</span>
    </div>
  </div>

  {Object.keys(latest.dependencies).length > 0 && (
    <div class="section">
      <p class="section-heading">dependencies</p>
      <div class="deps-list">
        {Object.entries(latest.dependencies).map(([dep, range]) => (
          <div class="dep-item">
            <a class="dep-name" href={`/packages/${dep}`}>{dep}</a>
            <span class="dep-range">{range}</span>
          </div>
        ))}
      </div>
    </div>
  )}

  <div class="section">
    <p class="section-heading">versions</p>
    <div class="versions-list">
      {versions.map((v, i) => (
        <div class="version-row">
          <div class="version-left">
            <span>v{v.version}</span>
            {i === 0 && <span class="version-tag">latest</span>}
          </div>
          <span class="version-date">{new Date(v.publishedAt).toLocaleDateString()}</span>
        </div>
      ))}
    </div>
  </div>
</Base>
