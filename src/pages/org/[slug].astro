---
import Base from '~/layouts/Base.astro'
import ProfileHeader from '~/components/profile/ProfileHeader.astro'
import PackageGrid from '~/components/profile/PackageGrid.astro'
import { getOrgBySlug, getUserByUsername, isOrgAdmin } from '~/lib/orgs.js'
import { getOrgFollowerCount } from '~/lib/users.js'
import { isFollowingOrg } from '~/lib/follows.js'
import { createServerClient, parseCookieHeader } from '@supabase/ssr'

const { slug } = Astro.params
const org = await getOrgBySlug(slug!)
const user = !org ? await getUserByUsername(slug!) : null

if (!org && !user) return Astro.redirect('/packages')

const { supabase } = await import('~/lib/supabase.js')

// Fetch packages for org or user
const ownerId = org ? org.id : user!.id
const ownerType = org ? 'org' : 'user'
const { data: packages } = await supabase
  .from('packages')
  .select('*, package_versions(*)')
  .eq('owner_id', ownerId)
  .eq('owner_type', ownerType)
  .order('created_at', { ascending: false })

let teams: any[] = []
let memberCount = 0
let teamMemberCounts: Record<string, number> = {}
let followerCount = 0

if (org) {
  const { data: t } = await supabase
    .from('org_teams')
    .select('*')
    .eq('org_id', org.id)
  teams = t ?? []

  const { count } = await supabase
    .from('org_members')
    .select('*', { count: 'exact', head: true })
    .eq('org_id', org.id)
    .then(r => ({ count: r.count ?? 0 }))
  memberCount = count

  const teamIds = teams.map(t => t.id)
  if (teamIds.length > 0) {
    const { data: teamMembers } = await supabase
      .from('org_team_members')
      .select('team_id')
      .in('team_id', teamIds)
    if (teamMembers) {
      for (const m of teamMembers) {
        teamMemberCounts[m.team_id] = (teamMemberCounts[m.team_id] ?? 0) + 1
      }
    }
  }

  // Fetch org follower count
  followerCount = await getOrgFollowerCount(org.id)
}

const isUser = !!user
const isOrg = !!org
const pageTitle = isOrg ? org.name : user!.user_name
const pageDescription = isOrg ? (org.description ?? `${org.name} on Lectern`) : `${user!.user_name} on Lectern`

// Check if viewer is org admin
const supabaseClient = createServerClient(
  import.meta.env.SUPABASE_URL ?? '',
  import.meta.env.SUPABASE_PUBLISHABLE_KEY ?? '',
  {
    cookies: {
      getAll() { return parseCookieHeader(Astro.request.headers.get('Cookie') ?? '') },
      setAll() {},
    },
  }
)

const { data: { session } } = await supabaseClient.auth.getSession()
const viewerId = session?.user.id

let isOwner = false
let isFollowing = false

if (org && viewerId) {
  isOwner = await isOrgAdmin(org.id, viewerId)
  isFollowing = await isFollowingOrg(viewerId, org.id)
}

// If visiting a user, redirect to /u/[username]
if (isUser) {
  return Astro.redirect(`/u/${user!.user_name}`)
}

// Prepare packages for grid
const packagesForGrid = (packages ?? []).map((p: any) => {
  const latestVersion = p.package_versions?.[0]
  return {
    name: p.name,
    slug: p.name,
    display_name: p.display_name,
    description: p.description,
    version: latestVersion?.version,
    star_count: p.star_count,
    created_at: p.created_at,
  }
})
---

<Base title={pageTitle} description={pageDescription}>
  <style>
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: var(--muted);
      text-decoration: none;
      margin-bottom: 1.5rem;
      transition: color 0.15s;
    }
    .back-link:hover {
      color: var(--text);
    }

    .tabs {
      display: flex;
      gap: 0;
      border-bottom: 1px solid var(--border);
      margin-bottom: 1.5rem;
    }

    .tab {
      font-family: var(--font-mono);
      font-size: 0.875rem;
      padding: 0.6rem 1.25rem;
      color: var(--muted);
      text-decoration: none;
      border-bottom: 2px solid transparent;
      margin-bottom: -1px;
      transition: color 0.15s, border-color 0.15s;
      cursor: pointer;
      background: none;
      border-top: none;
      border-left: none;
      border-right: none;
    }

    .tab:hover {
      color: var(--text);
    }

    .tab.active {
      color: var(--text);
      border-bottom-color: var(--accent);
    }

    .tab-content {
      display: none;
    }

    .tab-content.active {
      display: block;
    }

    .team-list {
      display: flex;
      flex-direction: column;
    }

    .team-card {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.875rem 1.25rem;
      margin-bottom: 0.5rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
    }

    .team-name {
      font-family: var(--font-mono);
      font-size: 0.9375rem;
      font-weight: 500;
    }

    .team-members {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: var(--muted);
    }

    .follower-list {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .follower-item {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.75rem 1rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      text-decoration: none;
      color: var(--text);
      transition: border-color 0.15s;
    }

    .follower-item:hover {
      border-color: var(--accent);
      opacity: 1;
    }

    .follower-avatar {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: var(--surface);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-mono);
      font-size: 0.875rem;
      font-weight: 600;
      color: white;
      flex-shrink: 0;
    }

    .follower-name {
      font-family: var(--font-mono);
      font-size: 0.875rem;
      font-weight: 500;
    }

    .empty {
      font-family: var(--font-mono);
      font-size: 0.875rem;
      color: var(--muted);
      padding: 2rem 0;
      text-align: center;
    }
  </style>

  <a class="back-link" href="/packages">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    packages
  </a>

  {isOrg && (
    <ProfileHeader
      type="org"
      name={org.name}
      slug={org.slug}
      avatarUrl={org.avatar_url}
      bannerUrl={org.banner_url}
      bio={org.description}
      isOwner={isOwner}
      editHref={`/org/${org.slug}/settings`}
      followerCount={followerCount}
      packageCount={packages?.length ?? 0}
      teamsCount={teams.length}
      membersCount={memberCount}
      isFollowing={isFollowing}
      isLoggedIn={!!viewerId}
    />
  )}

  {isOrg && (
    <div class="tabs">
      <button class="tab active" data-tab="packages">Packages</button>
      <button class="tab" data-tab="teams">Teams</button>
      <button class="tab" data-tab="followers">Followers</button>
    </div>
  )}

  {isOrg ? (
    <>
      <div id="tab-packages" class="tab-content active">
        <PackageGrid packages={packagesForGrid} emptyMessage="No packages published yet." />
      </div>

      <div id="tab-teams" class="tab-content">
        {teams.length === 0
          ? <p class="empty">No teams created yet.</p>
          : (
            <div class="team-list">
              {teams.map(team => (
                <div class="team-card">
                  <span class="team-name">{team.name}</span>
                  <span class="team-members">{teamMemberCounts[team.id] ?? 0} member{(teamMemberCounts[team.id] ?? 0) !== 1 ? 's' : ''}</span>
                </div>
              ))}
            </div>
          )
        }
      </div>

      <div id="tab-followers" class="tab-content">
        <div class="follower-list" id="org-followers-list" data-loaded="false">
          <p class="empty">Click to load followers...</p>
        </div>
      </div>
    </>
  ) : null}

  {isOrg && (
    <script>
      const tabs = document.querySelectorAll('.tab')
      const tabContents = document.querySelectorAll('.tab-content')

      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          const target = tab.getAttribute('data-tab')!

          tabs.forEach(t => t.classList.remove('active'))
          tab.classList.add('active')

          tabContents.forEach(tc => {
            tc.classList.remove('active')
            if (tc.id === `tab-${target}`) {
              tc.classList.add('active')
            }
          })

          if (target === 'followers') {
            const list = document.getElementById('org-followers-list')
            if (list && list.dataset.loaded !== 'true') {
              loadFollowers()
            }
          }
        })
      })

      async function loadFollowers() {
        const list = document.getElementById('org-followers-list')
        if (!list) return
        list.dataset.loaded = 'true'

        const slug = window.location.pathname.split('/').pop()
        try {
          const res = await fetch(`/api/orgs/${slug}/followers`)
          if (res.ok) {
            const data = await res.json()
            renderFollowerList(list, data.followers)
          }
        } catch {
          list.innerHTML = '<p class="empty">Failed to load followers.</p>'
        }
      }

      function renderFollowerList(container, users) {
        if (!users || users.length === 0) {
          container.innerHTML = '<p class="empty">No followers yet.</p>'
          return
        }

        function getAvatarColor(s) {
          let hash = 0
          for (let i = 0; i < s.length; i++) {
            hash = s.charCodeAt(i) + ((hash << 5) - hash)
          }
          const hue = hash % 360
          return `hsl(${hue}, 50%, 40%)`
        }

        container.innerHTML = users.map(user => `
          <a class="follower-item" href="/u/${user.userName}">
            <div class="follower-avatar" style="background: ${getAvatarColor(user.userName)}">${user.userName.charAt(0).toUpperCase()}</div>
            <span class="follower-name">@${user.userName}</span>
          </a>
        `).join('')
      }
    </script>
  )}
</Base>
