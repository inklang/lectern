---
import Base from '~/layouts/Base.astro'
---

<Base title="Blog">
  <section class="placeholder-page">
    <h1>Blog</h1>
    <p>The Ink blog is coming soon. Stay tuned for updates, tutorials, and announcements.</p>
  </section>
</Base>

<style>
  .placeholder-page {
    max-width: 40ch;
    margin: 0 auto;
    text-align: center;
    padding: 4rem 0;
  }

  h1 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  p {
    color: var(--muted);
    line-height: 1.6;
  }
</style>
