---
import Base from '../layouts/Base.astro'
import { createServerClient, parseCookieHeader } from '@supabase/ssr'
import { getFeedEvents, type FeedEvent } from '../lib/db.js'

const supabase = createServerClient(
  import.meta.env.SUPABASE_URL ?? '',
  import.meta.env.SUPABASE_PUBLISHABLE_KEY ?? '',
  {
    cookies: {
      getAll() {
        return parseCookieHeader(Astro.request.headers.get('Cookie') ?? '')
      },
      setAll() {},
    },
  }
)

const { data: { session } } = await supabase.auth.getSession()

if (!session) {
  return Astro.redirect('/login')
}

const PAGE_SIZE = 20
const page = Math.max(1, parseInt(Astro.url.searchParams.get('page') ?? '1'))
const offset = (page - 1) * PAGE_SIZE

const { events, total } = await getFeedEvents(session.user.id, PAGE_SIZE, offset)
const totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE))
const clampedPage = Math.min(page, totalPages)

function buildPageUrl(p: number) {
  const params = new URLSearchParams()
  params.set('page', String(p))
  return `/feed?${params.toString()}`
}

function timeAgo(dateStr: string): string {
  const date = new Date(dateStr)
  const now = new Date()
  const diffMs = now.getTime() - date.getTime()
  const diffSecs = Math.floor(diffMs / 1000)
  const diffMins = Math.floor(diffSecs / 60)
  const diffHours = Math.floor(diffMins / 60)
  const diffDays = Math.floor(diffHours / 24)

  if (diffDays > 30) {
    return date.toLocaleDateString()
  } else if (diffDays > 0) {
    return `${diffDays}d ago`
  } else if (diffHours > 0) {
    return `${diffHours}h ago`
  } else if (diffMins > 0) {
    return `${diffMins}m ago`
  } else {
    return 'just now'
  }
}

function getPaginationItems(currentPage: number, total: number): (number | '...')[] {
  const items: (number | '...')[] = []
  const range = new Set<number>()
  range.add(1)
  range.add(total)
  for (let i = Math.max(1, currentPage - 2); i <= Math.min(total, currentPage + 2); i++) {
    range.add(i)
  }
  const sorted = [...range].sort((a, b) => a - b)
  for (let i = 0; i < sorted.length; i++) {
    if (i > 0 && sorted[i] - sorted[i - 1] > 1) {
      items.push('...')
    }
    items.push(sorted[i])
  }
  return items
}

const paginationItems = getPaginationItems(clampedPage, totalPages)

function eventIcon(type: FeedEvent['type']): string {
  switch (type) {
    case 'new_package': return '+'
    case 'new_version': return '↑'
    case 'starred_package': return '★'
  }
}

function eventTitle(event: FeedEvent): string {
  switch (event.type) {
    case 'new_package': return `published a new package`
    case 'new_version': return `published`
    case 'starred_package': return `starred`
  }
}
---
<Base title="Your Feed — Lectern">
  <style>
    .page-header {
      margin-bottom: 2rem;
    }
    .page-header h1 {
      font-family: var(--font-mono);
      font-size: 1.25rem;
      font-weight: 600;
      letter-spacing: -0.02em;
      margin-bottom: 0.25rem;
    }
    .page-header p {
      font-size: 0.875rem;
      color: var(--muted);
    }

    .activity-feed {
      display: flex;
      flex-direction: column;
    }

    .activity-item {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      padding: 1rem 0;
      border-bottom: 1px solid var(--border);
    }
    .activity-item:last-child {
      border-bottom: none;
    }

    .activity-icon {
      width: 2rem;
      height: 2rem;
      border-radius: 50%;
      background: var(--surface);
      border: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.875rem;
      flex-shrink: 0;
      color: var(--accent);
    }

    .actor-avatar {
      width: 2rem;
      height: 2rem;
      border-radius: 50%;
      border: 1px solid var(--border);
      object-fit: cover;
      flex-shrink: 0;
    }

    .actor-avatar-fallback {
      width: 2rem;
      height: 2rem;
      border-radius: 50%;
      background: var(--surface);
      border: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.75rem;
      color: var(--muted);
      flex-shrink: 0;
    }

    .activity-content {
      flex: 1;
      min-width: 0;
    }

    .activity-title {
      font-family: var(--font-mono);
      font-size: 0.9rem;
      margin-bottom: 0.2rem;
    }
    .activity-title a {
      color: var(--text);
      text-decoration: none;
    }
    .activity-title a:hover {
      color: var(--accent);
    }
    .activity-title .actor-name {
      color: var(--accent);
    }

    .activity-meta {
      font-family: var(--font-mono);
      font-size: 0.775rem;
      color: var(--muted);
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
    }

    .activity-version {
      color: var(--accent);
    }

    .activity-description {
      font-size: 0.8rem;
      color: var(--muted);
      margin-top: 0.3rem;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .empty {
      font-family: var(--font-mono);
      font-size: 0.875rem;
      color: var(--muted);
      padding: 3rem 0;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1rem;
    }

    .empty-ctas {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
      justify-content: center;
    }

    .empty-cta {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      padding: 0.5rem 1rem;
      border-radius: 8px;
      border: 1px solid var(--border);
      background: var(--surface);
      color: var(--text);
      text-decoration: none;
      transition: border-color 0.15s, background 0.15s;
    }

    .empty-cta:hover {
      border-color: var(--accent);
      background: var(--bg);
      opacity: 1;
    }

    .pagination {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.25rem;
      margin-top: 2.5rem;
      padding-top: 2rem;
      border-top: 1px solid var(--border);
    }

    .page-btn {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      padding: 0.35rem 0.65rem;
      border-radius: 6px;
      border: 1px solid var(--border);
      background: transparent;
      color: var(--muted);
      text-decoration: none;
      transition: background 0.15s, color 0.15s, border-color 0.15s;
      min-width: 2rem;
      text-align: center;
    }

    .page-btn:hover {
      background: var(--surface);
      color: var(--text);
      opacity: 1;
      border-color: var(--accent);
    }

    .page-btn.active {
      background: var(--accent);
      color: #fff;
      border-color: var(--accent);
    }

    .page-btn.disabled {
      opacity: 0.25;
      pointer-events: none;
    }
  </style>

  <div class="page-header">
    <h1>Your Feed</h1>
    <p>Activity from people you follow</p>
  </div>

  <div class="activity-feed">
    {events.length === 0
      ? (
        <div class="empty">
          <span>Your feed is empty.</span>
          <div class="empty-ctas">
            <a href="/packages" class="empty-cta">Discover packages</a>
            <a href="/profile" class="empty-cta">Explore users</a>
          </div>
        </div>
      )
      : events.map(event => (
          <div class="activity-item">
            {event.actor.avatarUrl
              ? <img class="actor-avatar" src={event.actor.avatarUrl} alt={event.actor.username} />
              : <div class="actor-avatar-fallback">{event.actor.username[0].toUpperCase()}</div>
            }
            <div class="activity-content">
              <div class="activity-title">
                <span class="actor-name">@{event.actor.username}</span>
                {' '}{eventTitle(event)}
                {' '}<a href={`/${event.package.slug}`}>{event.package.name}</a>
                {event.version && <span class="activity-version">v{event.version}</span>}
              </div>
              <div class="activity-meta">
                <span>{timeAgo(event.publishedAt)}</span>
              </div>
              {event.package.description && (
                <p class="activity-description">{event.package.description}</p>
              )}
            </div>
          </div>
        ))
    }
  </div>

  {totalPages > 1 && (
    <nav class="pagination" aria-label="Pagination">
      <a
        class={`page-btn${clampedPage === 1 ? ' disabled' : ''}`}
        href={buildPageUrl(clampedPage - 1)}
        aria-label="Previous page"
      >←</a>

      {paginationItems.map(p => p === '...'
        ? <span class="page-btn disabled">…</span>
        : <a
            class={`page-btn${p === clampedPage ? ' active' : ''}`}
            href={buildPageUrl(p)}
          >{p}</a>
      )}

      <a
        class={`page-btn${clampedPage === totalPages ? ' disabled' : ''}`}
        href={buildPageUrl(clampedPage + 1)}
        aria-label="Next page"
      >→</a>
    </nav>
  )}
</Base>
