---
import Base from '../layouts/Base.astro'
import { listAllPackages } from '../lib/db.js'

const PAGE_SIZE = 20

const page = Math.max(1, parseInt(Astro.url.searchParams.get('page') ?? '1'))

// Get all packages and flatten to versions
const allPackagesMap = await listAllPackages()
const allVersions = Object.entries(allPackagesMap).flatMap(([name, versions]) =>
  Object.values(versions).map(v => ({ name, ...v }))
)

// Sort by published_at descending
allVersions.sort((a, b) =>
  new Date(b.published_at).getTime() - new Date(a.published_at).getTime()
)

const totalCount = allVersions.length
const totalPages = Math.max(1, Math.ceil(totalCount / PAGE_SIZE))
const clampedPage = Math.min(page, totalPages)
const paginatedVersions = allVersions.slice((clampedPage - 1) * PAGE_SIZE, clampedPage * PAGE_SIZE)

function buildPageUrl(p: number) {
  const params = new URLSearchParams()
  params.set('page', String(p))
  return `/activity?${params.toString()}`
}

function timeAgo(dateStr: string): string {
  const date = new Date(dateStr)
  const now = new Date()
  const diffMs = now.getTime() - date.getTime()
  const diffSecs = Math.floor(diffMs / 1000)
  const diffMins = Math.floor(diffSecs / 60)
  const diffHours = Math.floor(diffMins / 60)
  const diffDays = Math.floor(diffHours / 24)

  if (diffDays > 30) {
    return date.toLocaleDateString()
  } else if (diffDays > 0) {
    return `${diffDays}d ago`
  } else if (diffHours > 0) {
    return `${diffHours}h ago`
  } else if (diffMins > 0) {
    return `${diffMins}m ago`
  } else {
    return 'just now'
  }
}

// Compute pagination items in frontmatter
function getPaginationItems(currentPage: number, total: number): (number | '...')[] {
  const items: (number | '...')[] = []
  const range = new Set<number>()
  range.add(1)
  range.add(total)
  for (let i = Math.max(1, currentPage - 2); i <= Math.min(total, currentPage + 2); i++) {
    range.add(i)
  }
  const sorted = [...range].sort((a, b) => a - b)
  for (let i = 0; i < sorted.length; i++) {
    if (i > 0 && sorted[i] - sorted[i - 1] > 1) {
      items.push('...')
    }
    items.push(sorted[i])
  }
  return items
}

const paginationItems = getPaginationItems(clampedPage, totalPages)
---
<Base title="Activity — Lectern">
  <style>
    .page-header {
      margin-bottom: 2rem;
    }
    .page-header h1 {
      font-family: var(--font-mono);
      font-size: 1.25rem;
      font-weight: 600;
      letter-spacing: -0.02em;
      margin-bottom: 0.25rem;
    }
    .page-header p {
      font-size: 0.875rem;
      color: var(--muted);
    }

    .activity-feed {
      display: flex;
      flex-direction: column;
    }

    .activity-item {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      padding: 1rem 0;
      border-bottom: 1px solid var(--border);
    }
    .activity-item:last-child {
      border-bottom: none;
    }

    .activity-icon {
      width: 2rem;
      height: 2rem;
      border-radius: 50%;
      background: var(--surface);
      border: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.875rem;
      flex-shrink: 0;
      color: var(--accent);
    }

    .activity-content {
      flex: 1;
      min-width: 0;
    }

    .activity-title {
      font-family: var(--font-mono);
      font-size: 0.9rem;
      margin-bottom: 0.2rem;
    }
    .activity-title a {
      color: var(--text);
      text-decoration: none;
    }
    .activity-title a:hover {
      color: var(--accent);
    }

    .activity-meta {
      font-family: var(--font-mono);
      font-size: 0.775rem;
      color: var(--muted);
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
    }

    .activity-version {
      color: var(--accent);
    }

    .activity-description {
      font-size: 0.8rem;
      color: var(--muted);
      margin-top: 0.3rem;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .empty {
      font-family: var(--font-mono);
      font-size: 0.875rem;
      color: var(--muted);
      padding: 3rem 0;
      text-align: center;
    }

    .pagination {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.25rem;
      margin-top: 2.5rem;
      padding-top: 2rem;
      border-top: 1px solid var(--border);
    }

    .page-btn {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      padding: 0.35rem 0.65rem;
      border-radius: 6px;
      border: 1px solid var(--border);
      background: transparent;
      color: var(--muted);
      text-decoration: none;
      transition: background 0.15s, color 0.15s, border-color 0.15s;
      min-width: 2rem;
      text-align: center;
    }

    .page-btn:hover {
      background: var(--surface);
      color: var(--text);
      opacity: 1;
      border-color: var(--accent);
    }

    .page-btn.active {
      background: var(--accent);
      color: #fff;
      border-color: var(--accent);
    }

    .page-btn.disabled {
      opacity: 0.25;
      pointer-events: none;
    }
  </style>

  <div class="page-header">
    <h1>Activity Feed</h1>
    <p>Recent package publishes and version releases</p>
  </div>

  <div class="activity-feed">
    {paginatedVersions.length === 0
      ? <p class="empty">No activity yet.</p>
      : paginatedVersions.map(v => (
          <div class="activity-item">
            <div class="activity-icon" title="Version published">↑</div>
            <div class="activity-content">
              <div class="activity-title">
                <a href={`/${v.name}`}>{v.name}</a>
                <span class="activity-version">v{v.version}</span>
              </div>
              <div class="activity-meta">
                <span>{timeAgo(v.published_at)}</span>
                {v.author && <span>by {v.author}</span>}
              </div>
              {v.description && (
                <p class="activity-description">{v.description}</p>
              )}
            </div>
          </div>
        ))
    }
  </div>

  {totalPages > 1 && (
    <nav class="pagination" aria-label="Pagination">
      <a
        class={`page-btn${clampedPage === 1 ? ' disabled' : ''}`}
        href={buildPageUrl(clampedPage - 1)}
        aria-label="Previous page"
      >←</a>

      {paginationItems.map(p => p === '...'
        ? <span class="page-btn disabled">…</span>
        : <a
            class={`page-btn${p === clampedPage ? ' active' : ''}`}
            href={buildPageUrl(p)}
          >{p}</a>
      )}

      <a
        class={`page-btn${clampedPage === totalPages ? ' disabled' : ''}`}
        href={buildPageUrl(clampedPage + 1)}
        aria-label="Next page"
      >→</a>
    </nav>
  )}
</Base>
