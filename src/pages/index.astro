---
import Base from '../layouts/Base.astro'
import { listAllPackages } from '../lib/db.js'

const allPackagesMap = await listAllPackages()
const packages = Object.entries(allPackagesMap)
const totalVersions = packages.reduce((n, [, versions]) => n + Object.keys(versions).length, 0)

const recent = packages
  .flatMap(([name, versions]) =>
    Object.values(versions).map(v => ({ name, ...v }))
  )
  .sort((a, b) => new Date(b.published_at).getTime() - new Date(a.published_at).getTime())
  .slice(0, 6)
---
<Base title="Home">
  <style>
    .hero {
      padding-bottom: 4rem;
      margin-bottom: 4rem;
      border-bottom: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .hero h1 {
      font-family: var(--font-mono);
      font-size: 3.5rem;
      font-weight: 600;
      letter-spacing: -0.04em;
      margin-bottom: 0.75rem;
      line-height: 1.2;
    }

    .hero p {
      color: var(--muted);
      font-size: 0.9375rem;
      max-width: 440px;
      line-height: 1.65;
      margin: 0 auto;
    }

    .install-box {
      margin: 1.75rem auto 0;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      background: var(--surface);
      border: 1px solid var(--border);
      font-family: var(--font-mono);
      font-size: 0.875rem;
      padding: 0.6rem 1rem;
      border-radius: 10px;
      color: var(--text);
    }

    .install-box .prompt { color: var(--muted-2); }

    .stats {
      display: flex;
      gap: 3rem;
      margin-top: 2rem;
      justify-content: center;
    }

    .stat-num {
      font-family: var(--font-mono);
      font-size: 2rem;
      font-weight: 600;
      letter-spacing: -0.02em;
    }

    .stat-label {
      font-size: 0.8rem;
      color: var(--muted);
      margin-top: 0.1rem;
    }

    .section-heading {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 1rem;
    }

    .pkg-list { display: flex; flex-direction: column; }

    .pkg-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1rem 1.25rem;
      margin-bottom: 0.5rem;
      text-decoration: none;
      color: var(--text);
      transition: border-color 0.15s;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      gap: 1rem;
    }

    .pkg-row:hover { border-color: var(--accent); opacity: 1; }

    .pkg-name {
      font-family: var(--font-mono);
      font-size: 0.9rem;
    }

    .pkg-meta {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: var(--muted);
    }

    .view-all {
      display: inline-block;
      margin-top: 1.5rem;
      font-size: 0.875rem;
      color: var(--muted);
      text-decoration: none;
    }

    .view-all:hover { color: var(--text); opacity: 1; }

    .empty {
      font-family: var(--font-mono);
      font-size: 0.875rem;
      color: var(--muted);
      padding: 2rem 0;
    }
  </style>

  <div class="hero">
    <h1>the ink<br/>package registry.</h1>
    <p>Discover and publish grammar packages, scripts, and runtime extensions for the Ink programming language.</p>
    <div class="install-box">
      <span class="prompt">$</span>
      <span>quill add ink.mobs</span>
    </div>
    <div class="stats">
      <div>
        <div class="stat-num">{packages.length}</div>
        <div class="stat-label">packages</div>
      </div>
      <div>
        <div class="stat-num">{totalVersions}</div>
        <div class="stat-label">versions</div>
      </div>
    </div>
  </div>

  <p class="section-heading">recently published</p>
  {recent.length === 0
    ? <p class="empty">no packages yet.</p>
    : <div class="pkg-list">
        {recent.map(pkg => (
          <a class="pkg-row" href={`/packages/${pkg.name}`}>
            <span class="pkg-name">{pkg.name}</span>
            <span class="pkg-meta">v{pkg.version} &middot; {new Date(pkg.published_at).toLocaleDateString()}</span>
          </a>
        ))}
      </div>
  }
  {recent.length > 0 && <a class="view-all" href="/packages">view all packages →</a>}
</Base>
