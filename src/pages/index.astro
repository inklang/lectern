---
import Base from '../layouts/Base.astro'
import HealthBadge from '../components/HealthBadge.astro'
import { listAllPackages, listTags, getTrendingPackages, getPopularPackages, getHealthLeaders } from '../lib/db.js'
import { createServerClient, parseCookieHeader } from '@supabase/ssr'

const supabase = createServerClient(
  import.meta.env.SUPABASE_URL ?? '',
  import.meta.env.SUPABASE_PUBLISHABLE_KEY ?? '',
  {
    cookies: {
      getAll() { return parseCookieHeader(Astro.request.headers.get('Cookie') ?? '') },
      setAll() {},
    },
  }
)
const { data: { session } } = await supabase.auth.getSession()
const avatar = session?.user.user_metadata?.avatar_url ?? null
const username = session?.user.user_metadata?.user_name ?? null

const allPackagesMap = await listAllPackages()
const packages = Object.entries(allPackagesMap)
const totalVersions = packages.reduce((n, [, versions]) => n + Object.keys(versions).length, 0)
const totalDownloads = packages.reduce(
  (n, [, versions]) => n + Object.values(versions).reduce((s, v) => s + (v.download_count ?? 0), 0),
  0
)

const recent = packages
  .flatMap(([name, versions]) =>
    Object.values(versions).map(v => ({ name, ...v }))
  )
  .sort((a, b) => new Date(b.published_at).getTime() - new Date(a.published_at).getTime())
  .slice(0, 6)

const trending = await getTrendingPackages(7, 5).catch(() => [])
const featured = trending.slice(0, 3)
const popular = await getPopularPackages(5).catch(() => [])
const allTags = await listTags().catch(() => [])
const healthLeaders = await getHealthLeaders(5).catch(() => [])

const EXAMPLE_CODE = `import spawn_mob, Zombie from mobs;

mob Dragon {
    name: "Boss"
    health: 500
}

on event:player_death(player) {
    spawn_mob(Zombie, player.location)
}`
---

<Base title="Home" description="The Ink package registry — discover and publish grammar packages, scripts, and runtime extensions.">
  <style>
    /* Hero */
    .hero {
      text-align: center;
      padding: 4rem 2rem 3rem;
      max-width: 680px;
      margin: 0 auto;
    }
    .hero-title {
      font-family: var(--font-mono);
      font-size: clamp(3rem, 8vw, 5rem);
      font-weight: 700;
      letter-spacing: -0.04em;
      line-height: 1;
      margin-bottom: 0.75rem;
      background: linear-gradient(135deg, var(--text) 0%, var(--muted) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hero-tagline {
      font-size: 1.125rem;
      color: var(--muted);
      margin-bottom: 0.5rem;
    }
    .hero-sub {
      font-size: 0.9rem;
      color: var(--muted-2);
      margin-bottom: 2rem;
    }
    .hero-search {
      margin-bottom: 1.5rem;
    }
    .hero-search-wrap {
      position: relative;
      display: flex;
      align-items: center;
      max-width: 480px;
      margin: 0 auto;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    .hero-search-wrap:focus-within {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(139, 92, 246, 0.2);
    }
    .hero-search-icon {
      position: absolute;
      left: 0.875rem;
      color: var(--muted);
      pointer-events: none;
    }
    .hero-search-input {
      width: 100%;
      background: transparent;
      border: none;
      outline: none;
      padding: 0.75rem 1rem 0.75rem 2.75rem;
      font-family: var(--font-mono);
      font-size: 0.9375rem;
      color: var(--text);
    }
    .hero-search-input::placeholder { color: var(--muted-2); }
    .hero-search-input::-webkit-search-cancel-button { display: none; }
    .hero-ctas {
      display: flex;
      gap: 0.75rem;
      justify-content: center;
      flex-wrap: wrap;
    }
    .btn {
      display: inline-block;
      padding: 0.625rem 1.375rem;
      border-radius: 8px;
      font-size: 0.9rem;
      font-weight: 500;
      text-decoration: none;
      transition: background 0.15s, border-color 0.15s, opacity 0.15s;
      cursor: pointer;
    }
    .btn-primary {
      background: var(--accent);
      color: #fff;
      border: 1px solid var(--accent);
    }
    .btn-primary:hover { background: #7c3aed; border-color: #7c3aed; opacity: 1; }
    .btn-outline {
      background: transparent;
      color: var(--text);
      border: 1px solid var(--border);
    }
    .btn-outline:hover { border-color: var(--accent); opacity: 1; }

    /* Code preview */
    .code-preview {
      max-width: 640px;
      margin: 0 auto 3rem;
      padding: 0 2rem;
    }
    .code-preview-label {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      color: var(--muted-2);
      margin-bottom: 0.5rem;
      text-align: center;
      letter-spacing: 0.05em;
    }
    .code-block {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.25rem 1.5rem;
      overflow-x: auto;
    }
    .code-block pre {
      font-family: var(--font-mono);
      font-size: 0.875rem;
      line-height: 1.7;
      color: var(--text);
      margin: 0;
    }
    .code-block code {
      font-family: inherit;
    }

    /* Stats */
    .stats-row {
      display: flex;
      gap: 2rem;
      margin-bottom: 2.5rem;
      padding: 0 2rem;
      justify-content: center;
    }
    .stat {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .stat-num {
      font-family: var(--font-mono);
      font-size: 1.25rem;
      font-weight: 600;
    }
    .stat-label {
      font-size: 0.8rem;
      color: var(--muted);
    }

    /* Divider */
    .divider {
      border: none;
      border-top: 1px solid var(--border);
      max-width: 640px;
      margin: 0 auto 2.5rem;
    }

    /* Featured */
    .featured-section {
      max-width: 860px;
      margin: 0 auto 3rem;
      padding: 0 2rem;
    }
    .featured-heading {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.75rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .featured-heading::before { content: '★'; }
    .featured-list {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 0.75rem;
    }
    .featured-card {
      display: flex;
      flex-direction: column;
      padding: 1rem 1.25rem;
      text-decoration: none;
      color: var(--text);
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    .featured-card:hover {
      border-color: var(--accent);
      box-shadow: 0 0 0 1px var(--accent);
      opacity: 1;
    }
    .featured-card-name {
      font-family: var(--font-mono);
      font-size: 0.9rem;
      font-weight: 500;
      margin-bottom: 0.25rem;
    }
    .featured-card-desc {
      font-size: 0.8rem;
      color: var(--muted);
      margin-bottom: 0.5rem;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .featured-card-meta {
      display: flex;
      gap: 1rem;
      font-family: var(--font-mono);
      font-size: 0.75rem;
      color: var(--muted);
      margin-top: auto;
    }

    /* Activity sections */
    .home-sections {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
      max-width: 860px;
      margin: 0 auto;
      padding: 0 2rem 4rem;
    }
    @media (max-width: 768px) {
      .home-sections { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 480px) {
      .home-sections { grid-template-columns: 1fr; }
    }

    .section-heading {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted-2);
      margin-bottom: 0.75rem;
    }

    .pkg-list { display: flex; flex-direction: column; }
    .pkg-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.75rem 1rem;
      margin-bottom: 0.4rem;
      text-decoration: none;
      color: var(--text);
      transition: border-color 0.15s;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      gap: 1rem;
    }
    .pkg-row:hover { border-color: var(--accent); opacity: 1; }
    .pkg-name { font-family: var(--font-mono); font-size: 0.875rem; }
    .pkg-meta { font-family: var(--font-mono); font-size: 0.775rem; color: var(--muted); }

    .trending-list { display: flex; flex-direction: column; }
    .trending-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.75rem 1rem;
      margin-bottom: 0.4rem;
      text-decoration: none;
      color: var(--text);
      transition: border-color 0.15s;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      gap: 1rem;
    }
    .trending-row:hover { border-color: var(--accent); opacity: 1; }
    .trending-rank {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: var(--accent);
      min-width: 1.5rem;
    }
    .trending-name { font-family: var(--font-mono); font-size: 0.875rem; flex: 1; }
    .trending-dl { font-family: var(--font-mono); font-size: 0.775rem; color: var(--muted); }

    .view-all {
      display: inline-block;
      margin-top: 1rem;
      font-size: 0.8rem;
      color: var(--muted);
      text-decoration: none;
    }
    .view-all:hover { color: var(--text); opacity: 1; }

    .empty {
      font-family: var(--font-mono);
      font-size: 0.875rem;
      color: var(--muted);
      padding: 2rem 0;
    }

    .health-dots {
      display: flex;
      gap: 0.4rem;
      align-items: center;
    }
    .health-dot {
      display: inline-block;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      border: 1px solid;
    }
    .health-dot--excellent { background: var(--health-excellent); border-color: var(--health-excellent); }
    .health-dot--good { background: var(--health-good); border-color: var(--health-good); }
    .health-dot--fair { background: var(--health-fair); border-color: var(--health-fair); }
    .health-dot--poor { background: var(--health-poor); border-color: var(--health-poor); }
    .health-dot--unknown { background: transparent; border-color: var(--health-unknown); border-style: dashed; }
  </style>

  <!-- Hero -->
  <section class="hero">
    <h1 class="hero-title">ink</h1>
    <p class="hero-tagline">A compiled scripting language for PaperMC servers.</p>
    <p class="hero-sub">Packages extend the language itself.</p>
    <form class="hero-search" action="/search" method="get">
      <div class="hero-search-wrap">
        <svg class="hero-search-icon" width="16" height="16" viewBox="0 0 16 16" fill="none">
          <circle cx="6.5" cy="6.5" r="5" stroke="currentColor" stroke-width="1.5"/>
          <path d="M10.5 10.5L14 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <input
          type="search"
          name="q"
          class="hero-search-input"
          placeholder="Search packages…"
          autocomplete="off"
          aria-label="Search packages"
        />
      </div>
    </form>
    <div class="hero-ctas">
      <a href="/docs" class="btn btn-primary">Get Started</a>
      <a href="/docs/intro" class="btn btn-outline">Learn More</a>
    </div>
  </section>

  <!-- Code preview -->
  <div class="code-preview">
    <p class="code-preview-label">After installing the mobs package:</p>
    <div class="code-block">
      <pre><code>{EXAMPLE_CODE}</code></pre>
    </div>
  </div>

  <!-- Stats -->
  <div class="stats-row">
    <div class="stat">
      <span class="stat-num">{packages.length}</span>
      <span class="stat-label">packages</span>
    </div>
    <div class="stat">
      <span class="stat-num">{totalVersions}</span>
      <span class="stat-label">versions</span>
    </div>
    <div class="stat">
      <span class="stat-num">{totalDownloads.toLocaleString()}</span>
      <span class="stat-label">downloads</span>
    </div>
    <div class="stat">
      <span class="stat-num">{allTags.length}</span>
      <span class="stat-label">tags</span>
    </div>
  </div>

  <hr class="divider" />

  <!-- Health Leaders -->
  {healthLeaders.length > 0 && (
    <div class="featured-section">
      <p class="featured-heading">Healthiest Packages</p>
      <div class="featured-list">
        {healthLeaders.map(leader => (
          <a class="featured-card" href={`/${leader.package_name}`}>
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.5rem;">
              <span class="featured-card-name">{leader.package_name}</span>
              <HealthBadge size="sm" score={leader.health_score} status={leader.health_status} />
            </div>
            <div class="health-dots">
              <span title={`Maintenance: ${leader.maintenance_status}`}><span class={`health-dot health-dot--${leader.maintenance_status}`}></span></span>
              <span title={`Popularity: ${leader.popularity_status}`}><span class={`health-dot health-dot--${leader.popularity_status}`}></span></span>
              <span title={`Quality: ${leader.quality_status}`}><span class={`health-dot health-dot--${leader.quality_status}`}></span></span>
              <span title={`Compliance: ${leader.compliance_status}`}><span class={`health-dot health-dot--${leader.compliance_status}`}></span></span>
            </div>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Featured packages -->
  {featured.length > 0 && (
    <div class="featured-section">
      <p class="featured-heading">Featured Packages</p>
      <div class="featured-list">
        {featured.map(pkg => (
          <a class="featured-card" href={`/${pkg.package_slug}`}>
            <span class="featured-card-name">{pkg.package_name}</span>
            {pkg.description && <span class="featured-card-desc">{pkg.description}</span>}
            <div class="featured-card-meta">
              <span>v{pkg.latest_version}</span>
              <span>{pkg.download_count.toLocaleString()} dl</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Activity sections -->
  <div class="home-sections">
    <div>
      <p class="section-heading">recently published</p>
      {recent.length === 0
        ? <p class="empty">no packages yet.</p>
        : <div class="pkg-list">
            {recent.map(pkg => (
              <a class="pkg-row" href={`/${pkg.name}`}>
                <span class="pkg-name">{pkg.name}</span>
                <span class="pkg-meta">v{pkg.version} · {new Date(pkg.published_at).toLocaleDateString()}</span>
              </a>
            ))}
          </div>
      }
      {recent.length > 0 && <a class="view-all" href="/packages">view all packages →</a>}
    </div>

    <div>
      <p class="section-heading">trending this week</p>
      {trending.length === 0
        ? <p class="empty">no download data yet.</p>
        : <div class="trending-list">
            {trending.map((pkg, i) => (
              <a class="trending-row" href={`/${pkg.package_slug}`}>
                <span class="trending-rank">#{i + 1}</span>
                <span class="trending-name">{pkg.package_name}</span>
                <span class="trending-dl">{pkg.download_count.toLocaleString()} dl</span>
              </a>
            ))}
          </div>
      }
    </div>

    <div>
      <p class="section-heading">top packages</p>
      {popular.length === 0
        ? <p class="empty">no packages yet.</p>
        : <div class="trending-list">
            {popular.map((pkg, i) => (
              <a class="trending-row" href={`/${pkg.package_slug}`}>
                <span class="trending-rank">#{i + 1}</span>
                <span class="trending-name">{pkg.package_name}</span>
                <span class="trending-dl">{pkg.popularity_score.toFixed(2)}</span>
              </a>
            ))}
          </div>
      }
      {popular.length > 0 && <a class="view-all" href="/packages?sort=popular">view all →</a>}
    </div>
  </div>
</Base>
