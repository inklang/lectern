---
import Base from '../layouts/Base.astro'
---
<Base title="Login">
  <style>
    h1 {
      font-family: var(--font-mono);
      font-size: 1.25rem;
      font-weight: 600;
      letter-spacing: -0.02em;
      margin-bottom: 2.5rem;
    }

    .login-row {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1rem 0;
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }

    .login-label {
      flex: 1;
      font-size: 0.875rem;
      color: var(--muted);
    }

    .btn {
      font-family: var(--font-mono);
      font-size: 0.775rem;
      padding: 0.3rem 0.75rem;
      border-radius: 6px;
      border: 1px solid var(--border);
      background: transparent;
      color: var(--muted);
      cursor: pointer;
      white-space: nowrap;
      transition: color 0.15s, border-color 0.15s;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
    }

    .btn:hover { color: var(--text); border-color: var(--text); opacity: 1; }
  </style>

  <h1>login</h1>

  <div class="login-row">
    <span class="login-label">sign in with GitHub to publish packages</span>
    <a class="btn" href="/api/auth/login">login with github</a>
  </div>
</Base>
