---
import Base from '../layouts/Base.astro'
import { createServerClient, parseCookieHeader } from '@supabase/ssr'

const supabase = createServerClient(
  import.meta.env.SUPABASE_URL ?? '',
  import.meta.env.SUPABASE_PUBLISHABLE_KEY ?? '',
  {
    cookies: {
      getAll() {
        return parseCookieHeader(Astro.request.headers.get('Cookie') ?? '')
      },
      setAll() {},
    },
  }
)

const { data: { session } } = await supabase.auth.getSession()

if (!session) {
  return Astro.redirect('/login')
}

const user = session.user
const username = user.user_metadata?.user_name ?? 'User'
const email = user.email ?? ''
const avatar = user.user_metadata?.avatar_url ?? ''
const supabaseUrl = import.meta.env.SUPABASE_URL ?? ''
const supabaseKey = import.meta.env.SUPABASE_PUBLISHABLE_KEY ?? ''
const accessToken = session.access_token
---
<Base title="Profile">
  <style is:global>
    h1 {
      font-family: var(--font-mono);
      font-size: 1.25rem;
      font-weight: 600;
      letter-spacing: -0.02em;
      margin-bottom: 2.5rem;
    }

    /* ── section ──────────────────────────────── */
    .section {
      margin-bottom: 2.5rem;
    }

    .section-heading {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 0.875rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    /* ── account ──────────────────────────────── */
    .account-row {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1rem 0;
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }

    .account-avatar {
      width: 2.75rem;
      height: 2.75rem;
      border-radius: 8px;
      object-fit: cover;
      flex-shrink: 0;
    }

    .account-info {
      flex: 1;
      min-width: 0;
    }

    .account-name {
      font-family: var(--font-mono);
      font-size: 0.9375rem;
      font-weight: 500;
      color: var(--text);
    }

    .account-email {
      font-size: 0.8rem;
      color: var(--muted);
      margin-top: 0.2rem;
    }

    /* ── shared row list ──────────────────────── */
    .row-list {
      display: flex;
      flex-direction: column;
    }

    .row-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.8rem 0;
      border-bottom: 1px solid var(--border);
      font-family: var(--font-mono);
      font-size: 0.875rem;
    }

    .row-item:first-child {
      border-top: 1px solid var(--border);
    }

    .row-left {
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
      min-width: 0;
    }

    .row-name {
      color: var(--text);
      text-decoration: none;
    }

    .row-name:hover { opacity: 0.7; }

    .row-meta {
      font-size: 0.775rem;
      color: var(--muted);
    }

    /* ── buttons ──────────────────────────────── */
    .btn {
      font-family: var(--font-mono);
      font-size: 0.775rem;
      padding: 0.3rem 0.75rem;
      border-radius: 6px;
      border: 1px solid var(--border);
      background: transparent;
      color: var(--muted);
      cursor: pointer;
      white-space: nowrap;
      transition: color 0.15s, border-color 0.15s;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
    }

    .btn:hover { color: var(--text); border-color: var(--text); opacity: 1; }
    .btn:disabled { opacity: 0.35; cursor: not-allowed; }

    .btn-danger {
      color: #f87171;
      border-color: #f87171;
    }

    .btn-danger:hover { color: #fca5a5; border-color: #fca5a5; }

    /* ── onboarding ──────────────────────────── */
    .onboarding {
      border-top: 1px solid var(--border);
      padding-top: 1.25rem;
    }

    .onboarding-title {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: var(--muted);
      margin-bottom: 1.25rem;
    }

    .steps {
      list-style: none;
      counter-reset: steps;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .steps li {
      counter-increment: steps;
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      padding-left: 1.5rem;
      position: relative;
    }

    .steps li::before {
      content: counter(steps);
      position: absolute;
      left: 0;
      font-family: var(--font-mono);
      font-size: 0.7rem;
      color: var(--muted-2);
      top: 0.1rem;
    }

    .step-label {
      font-size: 0.8rem;
      color: var(--muted);
    }

    .code-snippet {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 0.4rem 0.75rem;
      color: var(--text);
      display: block;
      width: fit-content;
    }

    .code-inline {
      font-family: var(--font-mono);
      font-size: 0.775rem;
      color: var(--text);
    }

    /* ── tokens blurb ─────────────────────────── */
    .tokens-blurb {
      font-size: 0.8rem;
      color: var(--muted);
      margin-bottom: 0.875rem;
    }

    /* ── token reveal ─────────────────────────── */
    .token-reveal {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--surface);
      border: 1px solid var(--accent);
      border-radius: 8px;
      padding: 0.75rem 1rem;
      margin-bottom: 1rem;
    }

    .token-reveal-note {
      font-size: 0.775rem;
      color: var(--muted);
      margin-bottom: 0.6rem;
      font-family: var(--font-mono);
    }

    .token-reveal-val {
      flex: 1;
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: var(--text);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    /* ── misc ─────────────────────────────────── */
    .empty {
      font-family: var(--font-mono);
      font-size: 0.875rem;
      color: var(--muted);
      padding: 1rem 0;
      border-top: 1px solid var(--border);
    }

    .loading {
      font-family: var(--font-mono);
      font-size: 0.875rem;
      color: var(--muted);
      padding: 1rem 0;
      border-top: 1px solid var(--border);
    }

    /* ── modal ─────────────────────────────────── */
    .modal {
      position: fixed;
      inset: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .modal-backdrop {
      position: absolute;
      inset: 0;
      background: rgba(0,0,0,0.6);
      backdrop-filter: blur(4px);
    }

    .modal-content {
      position: relative;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.5rem;
      width: 100%;
      max-width: 480px;
      margin: 1rem;
      box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    }

    .modal-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1.25rem;
    }

    .modal-header h2 {
      font-family: var(--font-mono);
      font-size: 1rem;
      font-weight: 600;
      letter-spacing: -0.02em;
      margin: 0;
    }

    .modal-close {
      background: none;
      border: none;
      color: var(--muted);
      cursor: pointer;
      padding: 0.25rem;
      display: flex;
      border-radius: 4px;
      transition: color 0.15s;
    }

    .modal-close:hover { color: var(--text); }

    .modal-error {
      background: rgba(239, 68, 68, 0.1);
      border: 1px solid rgba(239, 68, 68, 0.3);
      border-radius: 8px;
      padding: 0.75rem 1rem;
      color: #f87171;
      font-size: 0.875rem;
      margin-bottom: 1rem;
    }

    /* ── form (reused in modal) ─────────────────── */
    .form-group {
      margin-bottom: 1.25rem;
    }

    .form-label {
      display: block;
      font-family: var(--font-mono);
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 0.5rem;
    }

    .form-input {
      width: 100%;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 0.6rem 1rem;
      font-family: var(--font-mono);
      font-size: 0.875rem;
      color: var(--text);
      outline: none;
      transition: border-color 0.15s;
      box-sizing: border-box;
    }

    .form-input:focus { border-color: var(--accent); }

    .form-textarea {
      resize: vertical;
      min-height: 80px;
    }

    .form-hint {
      font-size: 0.775rem;
      color: var(--muted);
      margin-top: 0.4rem;
    }

    .slug-preview {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: var(--muted);
      margin-top: 0.4rem;
    }

    .slug-preview span { color: var(--text); }

    /* ── scope checkboxes ─────────────────────── */
    .scope-group {
      margin-bottom: 0.75rem;
    }

    .scope-category {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 0.35rem;
    }

    .scope-checkbox {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: var(--text);
      cursor: pointer;
      padding: 0.2rem 0;
    }

    .scope-checkbox input[type="checkbox"] {
      width: 14px;
      height: 14px;
      accent-color: var(--accent);
    }

    /* ── api token type badge ────────────────── */
    .token-type-badge {
      display: inline-block;
      font-family: var(--font-mono);
      font-size: 0.65rem;
      padding: 0.15rem 0.4rem;
      border-radius: 4px;
      background: var(--surface);
      border: 1px solid var(--border);
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .token-type-badge.admin { border-color: #f87171; color: #f87171; }
    .token-type-badge.org\:manage { border-color: #fb923c; color: #fb923c; }
    .token-type-badge.publish { border-color: #4ade80; color: #4ade80; }
    .token-type-badge.read { border-color: #60a5fa; color: #60a5fa; }

    /* ── mfa ─────────────────────────────────── */
    .mfa-factor-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .mfa-factor-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.75rem 0;
      border-top: 1px solid var(--border);
    }
    .mfa-factor-info {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    .mfa-factor-icon {
      width: 32px;
      height: 32px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .mfa-factor-icon svg {
      width: 18px;
      height: 18px;
      color: var(--accent);
    }
    .mfa-factor-label {
      font-size: 0.875rem;
    }
    .mfa-factor-date {
      font-size: 0.75rem;
      color: var(--muted);
      font-family: var(--font-mono);
    }
    .mfa-factor-status {
      font-size: 0.7rem;
      font-family: var(--font-mono);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .mfa-factor-status.verified { color: #4ade80; }
    .mfa-factor-status.unverified { color: #fb923c; }
    .mfa-empty {
      color: var(--muted);
      font-size: 0.875rem;
      padding: 0.5rem 0;
    }
    .mfa-modal-desc {
      font-size: 0.875rem;
      color: var(--muted);
      margin-bottom: 1rem;
    }
    .mfa-qr-container {
      display: flex;
      justify-content: center;
      margin-bottom: 1rem;
    }
    .mfa-qr-container img {
      border: 1px solid var(--border);
      border-radius: 8px;
    }
    .mfa-secret-label {
      font-size: 0.75rem;
      color: var(--muted);
      margin-bottom: 0.25rem;
    }
    .mfa-secret {
      display: block;
      font-family: var(--font-mono);
      font-size: 0.875rem;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 0.5rem;
      word-break: break-all;
      margin-bottom: 1rem;
    }
  </style>

  <div id="profile-container" data-url={supabaseUrl} data-key={supabaseKey} data-token={accessToken}>
    <h1>profile</h1>

    <!-- Account (server-rendered) -->
    <div class="section">
      <div class="section-heading">
        <span>account</span>
        <button class="btn" id="signout-btn">sign out</button>
      </div>
      <div class="account-row">
        {avatar && <img src={avatar} alt={username} class="account-avatar" />}
        <div class="account-info">
          <div class="account-name">{username}</div>
          <div class="account-email">{email}</div>
        </div>
      </div>
    </div>

    <!-- Packages (client-rendered) -->
    <div class="section" id="packages-section">
      <div class="section-heading">packages</div>
      <div class="loading">loading…</div>
    </div>

    <!-- Organizations (client-rendered) -->
    <div class="section" id="orgs-section">
      <div class="section-heading">organizations</div>
      <div class="loading">loading…</div>
    </div>

    <!-- CLI Tokens (client-rendered) -->
    <div class="section" id="tokens-section">
      <div class="section-heading">
        <span>cli tokens</span>
      </div>
      <div class="loading">loading…</div>
    </div>

    <!-- API Tokens (client-rendered) -->
    <div class="section" id="api-tokens-section">
      <div class="section-heading">
        <span>api tokens</span>
      </div>
      <div class="loading">loading…</div>
    </div>

    <!-- MFA (client-rendered) -->
    <div class="section" id="mfa-section">
      <div class="section-heading">
        <span>two-factor authentication</span>
        <button class="btn" id="mfa-enroll-btn">enable authenticator</button>
      </div>
      <div id="mfa-factors-list" class="loading">loading…</div>
    </div>
  </div>

  <!-- MFA Modal -->
  <div id="mfa-modal" class="modal" style="display:none">
    <div class="modal-backdrop" id="mfa-modal-backdrop"></div>
    <div class="modal-content">
      <div class="modal-header">
        <h2 id="mfa-modal-title">enable authenticator</h2>
        <button class="modal-close" id="mfa-modal-close-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
      </div>
      <div id="mfa-modal-error" class="modal-error" style="display:none"></div>
      <div id="mfa-enroll-step">
        <p class="mfa-modal-desc">Scan this QR code with your authenticator app (Google Authenticator, Authy, etc.)</p>
        <div class="mfa-qr-container">
          <img id="mfa-qr-code" src="" alt="QR Code" style="display:none" />
          <div id="mfa-qr-loading" class="loading">generating…</div>
        </div>
        <p class="mfa-secret-label">Or enter this secret manually:</p>
        <code class="mfa-secret" id="mfa-secret"></code>
      </div>
      <form id="mfa-verify-form" novalidate>
        <div class="form-group">
          <label class="form-label" for="mfa-code-input">verification code</label>
          <input id="mfa-code-input" class="form-input" type="text" inputmode="numeric" pattern="[0-9]*" autocomplete="one-time-code" maxlength="6" placeholder="000000" />
        </div>
        <button id="mfa-verify-btn" class="btn" type="submit">verify and enable</button>
      </form>
    </div>
  </div>

  <!-- New Org Modal -->
  <div id="new-org-modal" class="modal" style="display:none">
    <div class="modal-backdrop" id="modal-backdrop"></div>
    <div class="modal-content">
      <div class="modal-header">
        <h2>create organization</h2>
        <button class="modal-close" id="modal-close-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
      </div>
      <div id="modal-form-error" class="modal-error" style="display:none"></div>
      <form id="new-org-form" novalidate>
        <div class="form-group" id="slug-field" style="display:none">
          <label class="form-label" for="modal-slug-input">slug</label>
          <input id="modal-slug-input" class="form-input" type="text" autocomplete="off" spellcheck="false" minlength="3" maxlength="32" />
          <div class="slug-preview">lectern.sh/<span id="modal-slug-preview">—</span></div>
          <div class="form-hint" id="modal-slug-hint"></div>
        </div>
        <div class="form-group">
          <label class="form-label" for="modal-name-input">name</label>
          <input id="modal-name-input" class="form-input" type="text" placeholder="My Organization" maxlength="64" />
        </div>
        <div class="form-group">
          <label class="form-label" for="modal-desc-input">description <span style="opacity:0.5">(optional)</span></label>
          <textarea id="modal-desc-input" class="form-input form-textarea" placeholder="A brief description" maxlength="256"></textarea>
        </div>
        <button id="modal-submit-btn" class="btn" type="submit">Create Organization</button>
      </form>
    </div>
  </div>

  <!-- New API Token Modal -->
  <div id="new-api-token-modal" class="modal" style="display:none">
    <div class="modal-backdrop" id="api-token-modal-backdrop"></div>
    <div class="modal-content">
      <div class="modal-header">
        <h2>create api token</h2>
        <button class="modal-close" id="api-token-modal-close-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
      </div>
      <div id="api-token-modal-error" class="modal-error" style="display:none"></div>
      <form id="new-api-token-form" novalidate>
        <div class="form-group">
          <label class="form-label" for="api-token-name-input">name</label>
          <input id="api-token-name-input" class="form-input" type="text" placeholder="GitHub Actions" maxlength="64" required />
        </div>
        <div class="form-group">
          <label class="form-label" for="api-token-desc-input">description <span style="opacity:0.5">(optional)</span></label>
          <textarea id="api-token-desc-input" class="form-input form-textarea" placeholder="CI pipeline for my repo" maxlength="256"></textarea>
        </div>
        <div class="form-group">
          <label class="form-label">scopes</label>
          <div class="scope-group">
            <div class="scope-category">Packages</div>
            <label class="scope-checkbox"><input type="checkbox" id="scope-packages_read" checked /> packages: read</label>
            <label class="scope-checkbox"><input type="checkbox" id="scope-packages_publish" /> packages: publish</label>
            <label class="scope-checkbox"><input type="checkbox" id="scope-packages_delete" /> packages: delete</label>
          </div>
          <div class="scope-group">
            <div class="scope-category">Organizations</div>
            <label class="scope-checkbox"><input type="checkbox" id="scope-orgs_read" checked /> orgs: read</label>
            <label class="scope-checkbox"><input type="checkbox" id="scope-orgs_manage" /> orgs: manage</label>
            <label class="scope-checkbox"><input type="checkbox" id="scope-orgs_delete" /> orgs: delete</label>
          </div>
          <div class="scope-group">
            <div class="scope-category">Teams</div>
            <label class="scope-checkbox"><input type="checkbox" id="scope-teams_read" checked /> teams: read</label>
            <label class="scope-checkbox"><input type="checkbox" id="scope-teams_manage" /> teams: manage</label>
          </div>
          <div class="scope-group">
            <div class="scope-category">Tokens</div>
            <label class="scope-checkbox"><input type="checkbox" id="scope-tokens_read" checked /> tokens: read</label>
            <label class="scope-checkbox"><input type="checkbox" id="scope-tokens_write" /> tokens: write</label>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label" for="api-token-expiry-input">expiration</label>
          <select id="api-token-expiry-input" class="form-input">
            <option value="3600">1 hour</option>
            <option value="86400">1 day</option>
            <option value="604800">7 days</option>
            <option value="2592000" selected>30 days</option>
            <option value="">Never</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label" for="api-token-rate-limit-input">rate limit</label>
          <select id="api-token-rate-limit-input" class="form-input">
            <option value="10">10/min</option>
            <option value="100" selected>100/min</option>
            <option value="1000">1000/min</option>
            <option value="">Unlimited</option>
          </select>
        </div>
        <button id="api-token-submit-btn" class="btn" type="submit">Create Token</button>
      </form>
    </div>
  </div>

  <!-- API Token Reveal Modal -->
  <div id="api-token-reveal-modal" class="modal" style="display:none">
    <div class="modal-backdrop" id="api-token-reveal-backdrop"></div>
    <div class="modal-content">
      <div class="modal-header">
        <h2>token created</h2>
        <button class="modal-close" id="api-token-reveal-close-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
      </div>
      <p class="token-reveal-note">Save this token — it won't be shown again.</p>
      <div class="token-reveal">
        <span class="token-reveal-val" id="api-token-reveal-value"></span>
        <button class="btn" id="api-token-copy-btn">copy</button>
      </div>
      <p class="token-reveal-note" style="margin-top:0.5rem">Use it in your CI/CD pipeline:</p>
      <code class="code-snippet" id="api-token-reveal-env"></code>
    </div>
  </div>

  <script>
    import { createClient } from '@supabase/supabase-js'

    const container = document.getElementById('profile-container') as HTMLDivElement
    const supabaseUrl = container.dataset.url!
    const supabaseKey = container.dataset.key!
    const accessToken = container.dataset.token!
    const supabase = createClient(supabaseUrl, supabaseKey, {
      global: { headers: { Authorization: `Bearer ${accessToken}` } },
      auth: { persistSession: false },
    })

    document.getElementById('signout-btn')?.addEventListener('click', async () => {
      await fetch('/api/auth/logout', { method: 'POST' })
      window.location.href = '/'
    })

    async function load() {
      // Orgs
      const orgsSection = document.getElementById('orgs-section')!
      try {
        const { data: memberships, error: mErr } = await supabase
          .from('org_members')
          .select('role, org_id')
          .order('joined_at', { ascending: false })

        if (memberships && memberships.length > 0) {
          const orgIds = memberships.map((m: any) => m.org_id)
          const { data: orgs, error: oErr } = await supabase
            .from('orgs')
            .select('id, slug, name')
            .in('id', orgIds)

          const orgMap: Record<string, any> = {}
          if (orgs) {
            for (const org of orgs) {
              orgMap[org.id] = org
            }
          }

          const rows = memberships.map((m: any) => {
            const org = orgMap[m.org_id]
            if (!org) return ''
            return `
              <div class="row-item">
                <a href="/${encodeURIComponent(org.slug)}" class="row-name">${escapeHtml(org.name)}</a>
                <span class="row-meta">@${escapeHtml(org.slug)} · ${m.role}</span>
              </div>
            `
          }).join('')
          orgsSection.innerHTML = `<div class="section-heading">organizations</div><div class="row-list">${rows}</div>`
        } else {
          orgsSection.innerHTML = `
            <div class="section-heading">organizations</div>
            <p class="empty">you are not a member of any organizations.</p>
            <div class="onboarding">
              <button class="btn" id="new-org-btn" style="margin-top:0.75rem">+ create organization</button>
            </div>
          `
          document.getElementById('new-org-btn')?.addEventListener('click', openNewOrgModal)
        }
      } catch {
        orgsSection.innerHTML = `<div class="section-heading">organizations</div><p class="empty">error loading organizations.</p>`
      }

      // Packages
      const packagesSection = document.getElementById('packages-section')!
      try {
        const { data: packages } = await supabase
          .from('packages')
          .select('name, created_at')
          .order('created_at', { ascending: false })

        if (packages && packages.length > 0) {
          const rows = packages.map((pkg: any) => `
            <div class="row-item">
              <a href="/packages/${encodeURIComponent(pkg.name)}" class="row-name">${escapeHtml(pkg.name)}</a>
              <span class="row-meta">${formatDate(new Date(pkg.created_at))}</span>
            </div>
          `).join('')
          packagesSection.innerHTML = `<div class="section-heading">packages</div><div class="row-list">${rows}</div>`
        } else {
          packagesSection.innerHTML = `
            <div class="section-heading">packages</div>
            <div class="onboarding">
              <p class="onboarding-title">publish your first package</p>
              <ol class="steps">
                <li>
                  <span class="step-label">install quill</span>
                  <code class="code-snippet">npm install -g @inklang/quill</code>
                </li>
                <li>
                  <span class="step-label">authenticate — create a token below, then run</span>
                  <code class="code-snippet">quill login &lt;token&gt;</code>
                </li>
                <li>
                  <span class="step-label">publish from your package directory</span>
                  <code class="code-snippet">quill publish</code>
                </li>
              </ol>
            </div>
          `
        }
      } catch {
        packagesSection.innerHTML = `<div class="section-heading">packages</div><p class="empty">error loading packages.</p>`
      }

      // Tokens
      const tokensSection = document.getElementById('tokens-section')!
      await renderTokens(tokensSection)

      // API Tokens
      const apiTokensSection = document.getElementById('api-tokens-section')!
      await renderApiTokens(apiTokensSection)
    }

    async function renderTokens(tokensSection: HTMLElement) {
      // Preserve any existing reveal box across re-renders
      const existingReveal = tokensSection.querySelector('.token-reveal-wrap')?.cloneNode(true) as HTMLElement | null

      try {
        const { data: tokens } = await supabase
          .from('cli_tokens')
          .select('id, created_at, last_used')
          .order('created_at', { ascending: false })

        const heading = `
          <div class="section-heading">
            <span>cli tokens</span>
            <button class="btn" id="new-token-btn">+ new token</button>
          </div>
        `
        const blurb = `<p class="tokens-blurb">tokens let the quill CLI authenticate as you when publishing packages.</p>`

        if (tokens && tokens.length > 0) {
          const rows = tokens.map((token: any) => {
            const created = formatDate(new Date(token.created_at))
            const lastUsed = token.last_used ? formatDate(new Date(token.last_used)) : 'never'
            return `
              <div class="row-item" data-token-id="${escapeHtml(token.id)}">
                <div class="row-left">
                  <span class="row-name">${token.id.slice(0, 8)}…</span>
                  <span class="row-meta">created ${created} · last used ${lastUsed}</span>
                </div>
                <button class="btn btn-danger revoke-btn" data-token-id="${escapeHtml(token.id)}">revoke</button>
              </div>
            `
          }).join('')
          tokensSection.innerHTML = `${heading}${blurb}<div class="row-list">${rows}</div>`
        } else {
          tokensSection.innerHTML = `${heading}${blurb}<p class="empty">no tokens yet — create one to start publishing.</p>`
        }

        // Re-insert reveal if it existed
        if (existingReveal) {
          tokensSection.querySelector('.tokens-blurb')!.after(existingReveal)
          tokensSection.querySelector('#copy-token-btn')?.addEventListener('click', handleCopy)
        }

        document.getElementById('new-token-btn')?.addEventListener('click', createToken)

        tokensSection.querySelectorAll('.revoke-btn').forEach(btn => {
          btn.addEventListener('click', async (e) => {
            const tokenId = (e.target as HTMLElement).getAttribute('data-token-id')!
            const b = e.target as HTMLButtonElement
            b.disabled = true
            b.textContent = 'revoking…'
            try {
              await supabase.from('cli_tokens').delete().eq('id', tokenId)
              tokensSection.querySelector(`[data-token-id="${tokenId}"]`)?.remove()
            } catch {
              b.disabled = false
              b.textContent = 'revoke'
            }
          })
        })
      } catch {
        tokensSection.innerHTML = `<div class="section-heading">cli tokens</div><p class="empty">error loading tokens.</p>`
      }
    }

    let pendingToken = ''

    async function createToken() {
      const btn = document.getElementById('new-token-btn') as HTMLButtonElement
      btn.disabled = true
      btn.textContent = 'creating…'

      try {
        const res = await fetch('/api/auth/token', { method: 'POST' })
        const { token } = await res.json()
        pendingToken = token

        const tokensSection = document.getElementById('tokens-section')!
        const existing = tokensSection.querySelector('.token-reveal-wrap')
        if (existing) existing.remove()

        const wrap = document.createElement('div')
        wrap.className = 'token-reveal-wrap'
        wrap.innerHTML = `
          <p class="token-reveal-note">save this token — it won't be shown again.</p>
          <div class="token-reveal">
            <span class="token-reveal-val" title="${escapeHtml(token)}">${escapeHtml(token)}</span>
            <button class="btn" id="copy-token-btn">copy</button>
          </div>
          <p class="token-reveal-note" style="margin-top:0.5rem">then authenticate the cli: <code class="code-inline">quill login ${escapeHtml(token)}</code></p>
        `
        tokensSection.querySelector('.tokens-blurb')!.after(wrap)
        tokensSection.querySelector('#copy-token-btn')?.addEventListener('click', handleCopy)

        await renderTokens(tokensSection)
      } catch {
        btn.disabled = false
        btn.textContent = '+ new token'
      }
    }

    async function handleCopy() {
      await navigator.clipboard.writeText(pendingToken)
      const btn = document.getElementById('copy-token-btn')!
      btn.textContent = 'copied!'
      setTimeout(() => { btn.textContent = 'copy' }, 2000)
    }

    // ── API Tokens ───────────────────────────────────────────────
    async function renderApiTokens(apiTokensSection: HTMLElement) {
      try {
        const res = await fetch('/api/tokens')
        if (!res.ok) {
          apiTokensSection.innerHTML = `<div class="section-heading">api tokens</div><p class="empty">error loading tokens.</p>`
          return
        }
        const { tokens } = await res.json()

        const heading = `
          <div class="section-heading">
            <span>api tokens</span>
            <button class="btn" id="new-api-token-btn">+ new token</button>
          </div>
        `
        const blurb = `<p class="tokens-blurb">api tokens provide scoped access for CI/CD and integrations.</p>`

        if (tokens && tokens.length > 0) {
          const rows = tokens.map((token: any) => {
            const created = formatDate(new Date(token.createdAt))
            const lastUsed = token.lastUsedAt ? formatDate(new Date(token.lastUsedAt)) : 'never'
            const expiresAt = token.expiresAt ? `expires ${formatDate(new Date(token.expiresAt))}` : 'never expires'
            const typeBadge = `<span class="token-type-badge ${token.tokenType}">${token.tokenType}</span>`
            return `
              <div class="row-item" data-token-id="${escapeHtml(token.id)}">
                <div class="row-left">
                  <span class="row-name">${escapeHtml(token.name)}</span>
                  <span class="row-meta">${escapeHtml(token.tokenPrefix)}… · ${typeBadge} · ${expiresAt}</span>
                  <span class="row-meta">created ${created} · last used ${lastUsed}</span>
                </div>
                <button class="btn btn-danger revoke-api-token-btn" data-token-id="${escapeHtml(token.id)}">revoke</button>
              </div>
            `
          }).join('')
          apiTokensSection.innerHTML = `${heading}${blurb}<div class="row-list">${rows}</div>`
        } else {
          apiTokensSection.innerHTML = `${heading}${blurb}<p class="empty">no api tokens yet.</p>`
        }

        document.getElementById('new-api-token-btn')?.addEventListener('click', openNewApiTokenModal)

        apiTokensSection.querySelectorAll('.revoke-api-token-btn').forEach(btn => {
          btn.addEventListener('click', async (e) => {
            const tokenId = (e.target as HTMLElement).getAttribute('data-token-id')!
            const b = e.target as HTMLButtonElement
            b.disabled = true
            b.textContent = 'revoking…'
            try {
              const res = await fetch(`/api/tokens/${encodeURIComponent(tokenId)}`, { method: 'DELETE' })
              if (res.ok) {
                apiTokensSection.querySelector(`[data-token-id="${tokenId}"]`)?.remove()
              } else {
                b.disabled = false
                b.textContent = 'revoke'
              }
            } catch {
              b.disabled = false
              b.textContent = 'revoke'
            }
          })
        })
      } catch {
        apiTokensSection.innerHTML = `<div class="section-heading">api tokens</div><p class="empty">error loading tokens.</p>`
      }
    }

    let pendingApiToken = ''

    function openNewApiTokenModal() {
      const modal = document.getElementById('new-api-token-modal')!
      const backdrop = document.getElementById('api-token-modal-backdrop')!
      const closeBtn = document.getElementById('api-token-modal-close-btn')!
      const form = document.getElementById('new-api-token-form') as HTMLFormElement
      const formError = document.getElementById('api-token-modal-error')!

      modal.style.display = 'flex'
      form.reset()
      formError.style.display = 'none'

      // Set default checked states
      ;(document.getElementById('scope-packages_read') as HTMLInputElement).checked = true
      ;(document.getElementById('scope-orgs_read') as HTMLInputElement).checked = true
      ;(document.getElementById('scope-teams_read') as HTMLInputElement).checked = true
      ;(document.getElementById('scope-tokens_read') as HTMLInputElement).checked = true
      ;(document.getElementById('scope-packages_publish') as HTMLInputElement).checked = false
      ;(document.getElementById('scope-packages_delete') as HTMLInputElement).checked = false
      ;(document.getElementById('scope-orgs_manage') as HTMLInputElement).checked = false
      ;(document.getElementById('scope-orgs_delete') as HTMLInputElement).checked = false
      ;(document.getElementById('scope-teams_manage') as HTMLInputElement).checked = false
      ;(document.getElementById('scope-tokens_write') as HTMLInputElement).checked = false
      ;(document.getElementById('api-token-expiry-input') as HTMLSelectElement).value = '2592000'
      ;(document.getElementById('api-token-rate-limit-input') as HTMLSelectElement).value = '100'

      function closeModal() {
        modal.style.display = 'none'
        form.reset()
        formError.style.display = 'none'
      }

      backdrop.addEventListener('click', closeModal)
      closeBtn.addEventListener('click', closeModal)

      form.addEventListener('submit', async (e) => {
        e.preventDefault()
        formError.style.display = 'none'
        const submitBtn = document.getElementById('api-token-submit-btn') as HTMLButtonElement
        submitBtn.disabled = true
        submitBtn.textContent = 'Creating…'

        const name = (document.getElementById('api-token-name-input') as HTMLInputElement).value.trim()
        const description = (document.getElementById('api-token-desc-input') as HTMLTextAreaElement).value.trim()

        if (!name) {
          formError.textContent = 'Name is required.'
          formError.style.display = 'block'
          submitBtn.disabled = false
          submitBtn.textContent = 'Create Token'
          return
        }

        const scopes = {
          packages_read: (document.getElementById('scope-packages_read') as HTMLInputElement).checked,
          packages_publish: (document.getElementById('scope-packages_publish') as HTMLInputElement).checked,
          packages_delete: (document.getElementById('scope-packages_delete') as HTMLInputElement).checked,
          orgs_read: (document.getElementById('scope-orgs_read') as HTMLInputElement).checked,
          orgs_manage: (document.getElementById('scope-orgs_manage') as HTMLInputElement).checked,
          orgs_delete: (document.getElementById('scope-orgs_delete') as HTMLInputElement).checked,
          teams_read: (document.getElementById('scope-teams_read') as HTMLInputElement).checked,
          teams_manage: (document.getElementById('scope-teams_manage') as HTMLInputElement).checked,
          tokens_read: (document.getElementById('scope-tokens_read') as HTMLInputElement).checked,
          tokens_write: (document.getElementById('scope-tokens_write') as HTMLInputElement).checked,
        }

        const expiresInSelect = document.getElementById('api-token-expiry-input') as HTMLSelectElement
        const expiresIn = expiresInSelect.value ? parseInt(expiresInSelect.value, 10) : null

        const rateLimitSelect = document.getElementById('api-token-rate-limit-input') as HTMLSelectElement
        const rateLimit = rateLimitSelect.value ? parseInt(rateLimitSelect.value, 10) : null

        try {
          const res = await fetch('/api/tokens', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name, description, scopes, expiresIn, rateLimit }),
          })

          if (res.ok) {
            const data = await res.json()
            pendingApiToken = data.token
            closeModal()

            // Show reveal modal
            const revealModal = document.getElementById('api-token-reveal-modal')!
            const revealBackdrop = document.getElementById('api-token-reveal-backdrop')!
            const revealCloseBtn = document.getElementById('api-token-reveal-close-btn')!
            const revealValue = document.getElementById('api-token-reveal-value')!
            const revealEnv = document.getElementById('api-token-reveal-env')!
            const copyBtn = document.getElementById('api-token-copy-btn')!

            revealModal.style.display = 'flex'
            revealValue.textContent = data.token
            revealEnv.textContent = `export LECTERN_TOKEN=${data.token}`

            async function handleApiTokenCopy() {
              await navigator.clipboard.writeText(pendingApiToken)
              copyBtn.textContent = 'copied!'
              setTimeout(() => { copyBtn.textContent = 'copy' }, 2000)
            }

            copyBtn.onclick = handleApiTokenCopy

            function closeRevealModal() {
              revealModal.style.display = 'none'
              copyBtn.onclick = null
            }

            revealBackdrop.addEventListener('click', closeRevealModal)
            revealCloseBtn.addEventListener('click', closeRevealModal)

            // Refresh the token list
            const apiTokensSection = document.getElementById('api-tokens-section')!
            await renderApiTokens(apiTokensSection)
          } else {
            const data = await res.json().catch(() => ({}))
            formError.textContent = data?.error ?? 'Failed to create token'
            formError.style.display = 'block'
          }
        } catch {
          formError.textContent = 'An unexpected error occurred.'
          formError.style.display = 'block'
        }

        submitBtn.disabled = false
        submitBtn.textContent = 'Create Token'
      })
    }

    function formatDate(date: Date): string {
      const now = new Date()
      const diff = now.getTime() - date.getTime()
      const days = Math.floor(diff / (1000 * 60 * 60 * 24))
      const hours = Math.floor(diff / (1000 * 60 * 60))
      const minutes = Math.floor(diff / (1000 * 60))

      if (days > 0) return `${days}d ago`
      if (hours > 0) return `${hours}h ago`
      if (minutes > 0) return `${minutes}m ago`
      return 'just now'
    }

    function escapeHtml(str: string): string {
      const div = document.createElement('div')
      div.textContent = str
      return div.innerHTML
    }

    // ── New Org Modal ──────────────────────────────────────────
    function openNewOrgModal() {
      const modal = document.getElementById('new-org-modal')!
      const backdrop = document.getElementById('modal-backdrop')!
      const closeBtn = document.getElementById('modal-close-btn')!
      const form = document.getElementById('new-org-form') as HTMLFormElement
      const slugField = document.getElementById('slug-field')!
      const slugInput = document.getElementById('modal-slug-input') as HTMLInputElement
      const nameInput = document.getElementById('modal-name-input') as HTMLInputElement
      const descInput = document.getElementById('modal-desc-input') as HTMLTextAreaElement
      const slugPreview = document.getElementById('modal-slug-preview')!
      const slugHint = document.getElementById('modal-slug-hint')!
      const submitBtn = document.getElementById('modal-submit-btn') as HTMLButtonElement
      const formError = document.getElementById('modal-form-error')!

      modal.style.display = 'flex'
      nameInput.focus()
      slugField.style.display = 'none'

      function nameToSlug(name: string): string {
        return name.toLowerCase().replace(/[^a-z0-9]/g, '-').replace(/-+/g, '-').replace(/^-|-$/g, '').slice(0, 32)
      }

      nameInput.addEventListener('blur', async () => {
        const name = nameInput.value.trim()
        if (!name) return

        const baseSlug = nameToSlug(name)
        slugPreview.textContent = baseSlug

        // Check if slug is available
        try {
          const res = await fetch(`/api/orgs/slug-availability?slug=${encodeURIComponent(baseSlug)}`)
          const data = await res.json()
          if (!data.available) {
            slugHint.textContent = `taken — ${data.suggestions?.join(', ') || 'edit to continue'}`
            slugHint.style.color = '#f87171'
            slugInput.value = baseSlug
            slugField.style.display = 'block'
            slugInput.focus()
          } else {
            slugField.style.display = 'none'
          }
        } catch {
          // on error, show slug field anyway
          slugField.style.display = 'none'
        }
      })

      slugInput.addEventListener('input', () => {
        const val = slugInput.value.toLowerCase().replace(/[^a-z0-9-]/g, '')
        slugInput.value = val
        slugPreview.textContent = val || '—'
      })

      function closeModal() {
        modal.style.display = 'none'
        form.reset()
        slugPreview.textContent = '—'
        formError.style.display = 'none'
        submitBtn.disabled = false
        submitBtn.textContent = 'Create Organization'
      }

      backdrop.addEventListener('click', closeModal)
      closeBtn.addEventListener('click', closeModal)

      form.addEventListener('submit', async (e) => {
        e.preventDefault()
        formError.style.display = 'none'
        submitBtn.disabled = true
        submitBtn.textContent = 'Creating…'

        const name = nameInput.value.trim()
        const description = descInput.value.trim()
        const slug = slugField.style.display === 'none'
          ? nameToSlug(name)
          : slugInput.value.trim()

        if (!name) {
          formError.textContent = 'Name is required.'
          formError.style.display = 'block'
          submitBtn.disabled = false
          submitBtn.textContent = 'Create Organization'
          return
        }

        if (!/^[a-z0-9-]+$/.test(slug) || slug.length < 3 || slug.length > 32) {
          formError.textContent = 'Please enter a valid slug (3-32 lowercase letters, numbers, and hyphens).'
          formError.style.display = 'block'
          submitBtn.disabled = false
          submitBtn.textContent = 'Create Organization'
          return
        }

        try {
          const res = await fetch('/api/orgs', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': `Bearer ${accessToken}`,
            },
            body: JSON.stringify({ slug, name, description }),
          })

          if (res.ok) {
            window.location.href = `/${encodeURIComponent(slug)}`
            return
          }

          const data = await res.json().catch(() => ({}))
          formError.textContent = data?.error ?? 'Failed to create organization'
          formError.style.display = 'block'
        } catch {
          formError.textContent = 'An unexpected error occurred.'
          formError.style.display = 'block'
        }

        submitBtn.disabled = false
        submitBtn.textContent = 'Create Organization'
      })
    }

    // ── MFA ─────────────────────────────────────────────────
    async function loadMfaFactors() {
      const factorsList = document.getElementById('mfa-factors-list')!
      const enrollBtn = document.getElementById('mfa-enroll-btn')!

      try {
        const res = await fetch('/api/auth/mfa/factors')
        if (!res.ok) {
          factorsList.innerHTML = '<div class="mfa-empty">failed to load</div>'
          return
        }
        const factors = await res.json()

        if (!factors || factors.length === 0) {
          factorsList.innerHTML = '<div class="mfa-empty">no authenticator enabled</div>'
          enrollBtn.textContent = 'enable authenticator'
          return
        }

        factorsList.innerHTML = `<ul class="mfa-factor-list">
          ${factors.map((f: any) => `
            <li class="mfa-factor-item">
              <div class="mfa-factor-info">
                <div class="mfa-factor-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                  </svg>
                </div>
                <div>
                  <div class="mfa-factor-label">Authenticator App</div>
                  <div class="mfa-factor-date">added ${new Date(f.createdAt).toLocaleDateString()}</div>
                </div>
              </div>
              <div style="display:flex;align-items:center;gap:0.75rem;">
                <span class="mfa-factor-status ${f.status}">${f.status}</span>
                <button class="btn" style="padding:0.375rem 0.75rem;font-size:0.75rem;" onclick="removeMfaFactor('${f.id}')">remove</button>
              </div>
            </li>
          `).join('')}
        </ul>`
        enrollBtn.textContent = 'add another'
      } catch {
        factorsList.innerHTML = '<div class="mfa-empty">failed to load</div>'
      }
    }

    // Make removeMfaFactor available globally
    (window as any).removeMfaFactor = async function(factorId: string) {
      if (!confirm('Are you sure you want to remove this authenticator? You will no longer be able to use it for two-factor authentication.')) {
        return
      }
      try {
        const res = await fetch(`/api/auth/mfa/factors/${factorId}`, { method: 'DELETE' })
        if (res.ok) {
          loadMfaFactors()
        } else {
          const data = await res.json()
          alert(data.error ?? 'Failed to remove factor')
        }
      } catch {
        alert('An error occurred')
      }
    }

    // ── MFA Modal ───────────────────────────────────────────
    let pendingFactorId: string | null = null

    function openMfaModal() {
      const modal = document.getElementById('mfa-modal')!
      const backdrop = document.getElementById('mfa-modal-backdrop')!
      const closeBtn = document.getElementById('mfa-modal-close-btn')!
      const form = document.getElementById('mfa-verify-form') as HTMLFormElement
      const formError = document.getElementById('mfa-modal-error')!
      const qrImg = document.getElementById('mfa-qr-code') as HTMLImageElement
      const qrLoading = document.getElementById('mfa-qr-loading')!
      const secretEl = document.getElementById('mfa-secret')!
      const codeInput = document.getElementById('mfa-code-input') as HTMLInputElement
      const verifyBtn = document.getElementById('mfa-verify-btn') as HTMLButtonElement

      modal.style.display = 'flex'
      formError.style.display = 'none'
      form.reset()

      // Start enrollment
      enrollMfa()

      async function enrollMfa() {
        qrImg.style.display = 'none'
        qrLoading.style.display = 'block'
        secretEl.textContent = ''

        try {
          const res = await fetch('/api/auth/mfa/enroll', { method: 'POST' })
          const data = await res.json()

          console.log('MFA enroll response:', JSON.stringify(data))

          if (!res.ok || data.error) {
            formError.textContent = data.error ?? 'Failed to start enrollment'
            formError.style.display = 'block'
            qrLoading.style.display = 'none'
            return
          }

          pendingFactorId = data.id
          console.log('QR code length:', data.qrCode?.length)
          console.log('QR code prefix:', data.qrCode?.substring(0, 50))

          if (data.existing) {
            // User has an unverified factor - they need to delete it first
            qrLoading.style.display = 'none'
            document.getElementById('mfa-enroll-step')!.innerHTML = `
              <p class="mfa-modal-desc">You have a pending enrollment from a previous attempt that was never verified. You'll need to remove it first.</p>
              <button id="mfa-delete-pending" class="btn" type="button" style="margin-top:1rem;background:#ef4444;">Remove and Start Over</button>
            `
            document.getElementById('mfa-delete-pending')?.addEventListener('click', async () => {
              try {
                const delRes = await fetch(`/api/auth/mfa/factors/${data.id}`, { method: 'DELETE' })
                if (delRes.ok) {
                  // Reload the factors list and close modal
                  loadMfaFactors()
                  closeModal()
                } else {
                  const delData = await delRes.json()
                  formError.textContent = delData.error ?? 'Failed to remove factor'
                  formError.style.display = 'block'
                }
              } catch {
                formError.textContent = 'An error occurred'
                formError.style.display = 'block'
              }
            })
          } else {
            qrImg.src = data.qrCode
            qrImg.style.display = 'block'
            qrLoading.style.display = 'none'
            secretEl.textContent = data.secret
          }
        } catch {
          formError.textContent = 'An error occurred. Please try again.'
          formError.style.display = 'block'
          qrLoading.style.display = 'none'
        }
      }

      function closeModal() {
        modal.style.display = 'none'
        form.reset()
        formError.style.display = 'none'
        pendingFactorId = null
      }

      backdrop.addEventListener('click', closeModal)
      closeBtn.addEventListener('click', closeModal)

      codeInput.addEventListener('input', () => {
        codeInput.value = codeInput.value.replace(/[^0-9]/g, '').slice(0, 6)
        formError.style.display = 'none'
      })

      form.addEventListener('submit', async (e) => {
        e.preventDefault()
        formError.style.display = 'none'

        const code = codeInput.value.trim()
        if (code.length !== 6) {
          formError.textContent = 'Please enter a 6-digit code'
          formError.style.display = 'block'
          return
        }

        if (!pendingFactorId) {
          formError.textContent = 'Session expired. Please try again.'
          formError.style.display = 'block'
          return
        }

        verifyBtn.disabled = true
        verifyBtn.textContent = 'verifying…'

        try {
          // Create challenge
          const challengeRes = await fetch('/api/auth/mfa/challenge', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ factorId: pendingFactorId }),
          })
          const challengeData = await challengeRes.json()

          if (!challengeRes.ok || challengeData.error) {
            formError.textContent = challengeData.error ?? 'Failed to create challenge'
            formError.style.display = 'block'
            verifyBtn.disabled = false
            verifyBtn.textContent = 'verify and enable'
            return
          }

          // Verify code
          const verifyRes = await fetch('/api/auth/mfa/verify-enroll', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              factorId: pendingFactorId,
              challengeId: challengeData.challengeId,
              code,
            }),
          })
          const verifyData = await verifyRes.json()

          if (!verifyRes.ok || verifyData.error) {
            formError.textContent = verifyData.error ?? 'Invalid code'
            formError.style.display = 'block'
            verifyBtn.disabled = false
            verifyBtn.textContent = 'verify and enable'
            return
          }

          // Success
          closeModal()
          loadMfaFactors()
        } catch {
          formError.textContent = 'An error occurred. Please try again.'
          formError.style.display = 'block'
          verifyBtn.disabled = false
          verifyBtn.textContent = 'verify and enable'
        }
      })
    }

    document.getElementById('mfa-enroll-btn')?.addEventListener('click', openMfaModal)

    load()
    loadMfaFactors()
  </script>
</Base>
