  </div>

  <div class="section">
    <p class="section-heading">versions</p>
    <div class="versions-list" id="versions-list">
      {versions.map((v, i) => (
        <div class="version-row" data-version={v.version}>
          <div class="version-left">
            {versions.length > 1 && (
              <input
                type="checkbox"
                class="version-checkbox"
                value={v.version}
                aria-label={`Select version ${v.version}`}
              />
            )}
            <span>v{v.version}</span>
            {i === 0 && <span class="version-tag">latest</span>}
          </div>
          <div style="display: flex; gap: 1rem; align-items: center;">
            <span class="download-count">{(v.download_count ?? 0).toLocaleString()} dl</span>
            <span class="version-date">{new Date(v.published_at).toLocaleDateString()}</span>
          </div>
        </div>
      ))}
