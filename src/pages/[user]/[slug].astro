// This is a stub to show the routing structure
---

<Base title={packageName!} description={latest.description ?? `${packageName!} on Lectern`}>
  <h1>{packageName}</h1>
  <p>Package page at new route: /{user}/{slug}</p>
  <p>Version: {latest.version}</p>
  <p>Description: {latest.description}</p>

  <!-- TODO: Add full package page content -->
  <p><a href={`/packages/${packageName}`}>View at old route</a></p>
</Base>
