  <div class="section">
    <p class="section-heading">dependents</p>
    <div class="deps-list">
      {dependents.length > 0 ? (
        <>
          <div class="dep-item">
            <span class="dep-name">{dependents.length} package{dependents.length !== 1 ? 's' : ''} depend{dependents.length === 1 ? 's' : ''} on this</span>
          </div>
          <a class="dependents-link" href={`/${user}/${slug}/deps`}>View dependency graph →</a>
          {Object.keys(latest.dependencies).length > 0 && (
            <div class="mini-deps-preview">
              <svg width="180" height="60" viewBox="0 0 180 60">
                {/* Center node (this package) */}
                <circle cx="90" cy="30" r="8" fill="var(--accent)" />
                {/* Dependency nodes (left) */}
                {Object.keys(latest.dependencies).slice(0, 3).map((dep, i) => {
                  const x = 20 + i * 35
                  const y = 30 + (i % 2 === 0 ? -15 : 15)
                  return (
                    <>
                      <circle cx={x} cy={y} r="5" fill="var(--border)" stroke="var(--muted)" />
                      <line x1={x + 5} y1={y} x2={82} y2={30} stroke="var(--muted)" stroke-opacity="0.4" stroke-width="1" stroke-dasharray="3 2" />
                    </>
                  )
                })}
                {/* Dependent nodes (right) */}
                {dependents.slice(0, 3).map((dep, i) => {
                  const x = 160 - i * 35
                  const y = 30 + (i % 2 === 0 ? -15 : 15)
                  return (
                    <>
                      <circle cx={x} cy={y} r="5" fill="#f59e0b" />
                      <line x1={x - 5} y1={y} x2={98} y2={30} stroke="#f59e0b" stroke-opacity="0.5" stroke-width="1" />
                    </>
                  )
                })}
              </svg>
              <a class="mini-preview-label" href={`/${user}/${slug}/deps`}>view full graph →</a>
            </div>
