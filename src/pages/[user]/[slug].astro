        <div class="badge-preview">
          <img src={`/api/badges/${encodeURIComponent(packageName)}/${encodeURIComponent(latest.version)}`} alt={`v${latest.version} badge`} />
        </div>
        <div class="badge-code">
          <button class="badge-copy" data-copy="markdown">copy</button>
          <code id="badge-version-md">![v${latest.version}]({Astro.url.origin}/api/badges/${encodeURIComponent(packageName)}/${encodeURIComponent(latest.version)})</code>
        </div>
      </div>
      <div class="badge-card">
        <p class="badge-card-label">downloads</p>
        <div class="badge-preview">
          <img src={`/api/badges/${encodeURIComponent(packageName)}/downloads`} alt="downloads badge" />
        </div>
        <div class="badge-code">
          <button class="badge-copy" data-copy="markdown">copy</button>
          <code id="badge-downloads-md">![downloads]({Astro.url.origin}/api/badges/${encodeURIComponent(packageName)}/downloads)</code>
        </div>
      </div>
      <div class="badge-card">
        <p class="badge-card-label">health</p>
        <div class="badge-preview">
          {health && health.health_status !== 'unknown' ? (
            <HealthBadge score={health.health_score} status={health.health_status} size="md" />
          ) : (
            <HealthBadge score={0} status="unknown" size="md" />
          )}
        </div>
        <div class="badge-code">
          <button class="badge-copy" data-copy="markdown">copy</button>
          <code id="badge-health-md">![health]({Astro.url.origin}/api/badges/${encodeURIComponent(packageName)}/health)</code>
        </div>
