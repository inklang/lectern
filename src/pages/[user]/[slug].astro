  {isOrgAdmin && (
    <div class="section">
      <div class="pending-releases-section" id="pending-releases-section" style="display: none;">
        <p class="pending-releases-heading">Pending Releases</p>
        <div id="pending-releases-list"></div>
      </div>
    </div>
  )}

  {versions.length > 1 && (
    <div class="compare-footer" id="compare-footer">
      <span class="compare-text">
        Comparing <span class="compare-version" id="compare-v1">v1.0.0</span>
        <span style="color: var(--muted)"> → </span>
        <span class="compare-version" id="compare-v2">v2.0.0</span>
      </span>
      <button class="compare-btn" id="compare-btn">Compare versions</button>
    </div>
  )}

  <Giscus term={packageName} />

  <script define:vars={{ packageName, accessToken: session?.access_token ?? null, user, slug }}>
    document.querySelectorAll('.badge-copy').forEach(btn => {
      btn.addEventListener('click', async () => {
        const codeEl = btn.parentElement?.querySelector('code')
        if (!codeEl) return
        const text = codeEl.textContent ?? ''
        await navigator.clipboard.writeText(text).catch(() => {})
        const orig = btn.textContent
        btn.textContent = 'copied!'
        setTimeout(() => { btn.textContent = orig }, 1500)
      })
    })

    // Compare versions functionality
    const checkboxes = document.querySelectorAll('.version-checkbox')
    const footer = document.getElementById('compare-footer')
    const compareV1 = document.getElementById('compare-v1')
    const compareV2 = document.getElementById('compare-v2')
    const compareBtn = document.getElementById('compare-btn')

    let selectedVersions = []

    function updateFooter() {
      if (selectedVersions.length === 2) {
        const sorted = [...selectedVersions].sort((a, b) => {
          const parseV = (v) => v.split('.').map(n => parseInt(n, 10) || 0)
          const aParts = parseV(a)
          const bParts = parseV(b)
          for (let i = 0; i < 3; i++) {
            if (aParts[i] !== bParts[i]) return aParts[i] - bParts[i]
          }
          return 0
        })
        compareV1.textContent = 'v' + sorted[0]
        compareV2.textContent = 'v' + sorted[1]
        footer?.classList.add('visible')
      } else {
        footer?.classList.remove('visible')
      }
    }

    checkboxes.forEach(cb => {
      cb.addEventListener('change', () => {
        const value = cb.value

        if (cb.checked) {
          if (selectedVersions.length >= 2) {
            const oldestVersion = selectedVersions.shift()
            checkboxes.forEach(otherCb => {
              if (otherCb.value === oldestVersion) otherCb.checked = false
            })
          }
          selectedVersions.push(value)
        } else {
          selectedVersions = selectedVersions.filter(v => v !== value)
        }

        updateFooter()
      })
    })

    compareBtn?.addEventListener('click', () => {
      if (selectedVersions.length === 2 && packageName) {
        const sorted = [...selectedVersions].sort((a, b) => {
          const parseV = (v) => v.split('.').map(n => parseInt(n, 10) || 0)
          const aParts = parseV(a)
          const bParts = parseV(b)
          for (let i = 0; i < 3; i++) {
            if (aParts[i] !== bParts[i]) return aParts[i] - bParts[i]
          }
          return 0
        })
        const [v1, v2] = sorted
        window.location.href = `/${user}/${slug}/diff?v1=${encodeURIComponent(v1)}&v2=${encodeURIComponent(v2)}`
      }
    })

    // Star button functionality
    const starBtn = document.getElementById('star-btn')
    const starCountEl = document.getElementById('star-count')
    if (starBtn) starBtn.dataset.token = accessToken ?? ''

    async function fetchStarStatus() {
      if (!packageName) return
      try {
        const res = await fetch(`/api/packages/${encodeURIComponent(packageName)}/star`)
        const data = await res.json()
        updateStarUI(data.starred, data.starCount ?? parseInt(starCountEl?.textContent ?? '0'))
      } catch {
        // Silently fail
      }
    }

    function updateStarUI(starred, count) {
      if (!starBtn || !starCountEl) return
      starBtn.dataset.starred = String(starred)
      starCountEl.textContent = String(count)
      if (starred) {
        starBtn.classList.add('starred')
        starBtn.querySelector('.star-icon').textContent = '★'
      } else {
        starBtn.classList.remove('starred')
        starBtn.querySelector('.star-icon').textContent = '☆'
      }
    }

    starBtn?.addEventListener('click', async () => {
      if (!packageName || !starBtn) return

      const isLoggedIn = starBtn.dataset.loggedIn === 'true'
      if (!isLoggedIn) {
        window.location.href = `/login?next=/${encodeURIComponent(packageName)}`
        return
      }

      const currentlyStarred = starBtn.dataset.starred === 'true'
      const currentCount = parseInt(starCountEl?.textContent ?? '0')

      // Loading state: disable during request
      starBtn.disabled = true
      updateStarUI(!currentlyStarred, currentlyStarred ? currentCount - 1 : currentCount + 1)

      // Trigger animation
      starBtn.classList.add('just-starred')
      setTimeout(() => starBtn.classList.remove('just-starred'), 300)

      try {
        const method = currentlyStarred ? 'DELETE' : 'PUT'
        const res = await fetch(`/api/packages/${encodeURIComponent(packageName)}/star`, {
          method,
          headers: {
            'Authorization': `Bearer ${starBtn.dataset.token ?? ''}`
          }
        })

        if (!res.ok) {
          updateStarUI(currentlyStarred, currentCount)
        } else {
          const data = await res.json()
          updateStarUI(data.starred, data.starCount ?? currentCount)
        }
      } catch {
        updateStarUI(currentlyStarred, currentCount)
      } finally {
        starBtn.disabled = false
      }
    })

    fetchStarStatus()

    // Health panel toggle
    const healthBadgeBtn = document.getElementById('health-badge-btn')
    const healthPanel = document.getElementById('health-panel')

    if (healthBadgeBtn && healthPanel) {
      // Show panel by default if it has content (not unknown)
      const isUnknown = healthPanel.querySelector('.health-panel__unknown') !== null
      if (!isUnknown) {
        healthPanel.hidden = false
        healthBadgeBtn.setAttribute('aria-expanded', 'true')
      }

      healthBadgeBtn.addEventListener('click', () => {
        const isHidden = healthPanel.hidden
        healthPanel.hidden = !isHidden
        healthBadgeBtn.setAttribute('aria-expanded', String(isHidden))
      })
    }

    // Pending releases functionality (for org admins)
    const pendingSection = document.getElementById('pending-releases-section')

    async function loadPendingReleases(name) {
      if (!pendingSection) return

      try {
        const res = await fetch(`/api/packages/${encodeURIComponent(name)}/releases/pending`)
        if (!res.ok) return

        const { releases } = await res.json()
        const list = document.getElementById('pending-releases-list')

        if (!releases || releases.length === 0) {
          pendingSection.style.display = 'none'
          return
        }

        pendingSection.style.display = 'block'
        list.innerHTML = releases.map(r => `
          <div class="pending-release">
            <span class="pending-release-version">${r.version}</span>
            <span class="pending-release-meta">by ${r.requested_by} · ${new Date(r.created_at).toLocaleDateString()}</span>
            <div class="pending-release-actions">
              <button class="pending-release-btn approve" onclick="approveRelease('${r.version}')">Approve</button>
              <button class="pending-release-btn reject" onclick="rejectRelease('${r.version}')">Reject</button>
            </div>
          </div>
        `).join('')
      } catch {
        // Silently fail
      }
    }

    window.approveRelease = async function(version) {
      if (!packageName) return
      try {
        const res = await fetch(`/api/packages/${encodeURIComponent(packageName)}/releases/pending/${encodeURIComponent(version)}/approve`, {
          method: 'POST',
          headers: {
            'Authorization': `Bearer ${starBtn?.dataset.token ?? ''}`
          }
        })

        if (res.ok) {
          loadPendingReleases(packageName)
        }
      } catch {
        // Silently fail
      }
    }

    window.rejectRelease = async function(version) {
      if (!packageName) return
      try {
        const res = await fetch(`/api/packages/${encodeURIComponent(packageName)}/releases/pending/${encodeURIComponent(version)}/reject`, {
          method: 'POST',
          headers: {
            'Authorization': `Bearer ${starBtn?.dataset.token ?? ''}`
          }
        })

        if (res.ok) {
          loadPendingReleases(packageName)
        }
      } catch {
        // Silently fail
      }
    }

    if (pendingSection) {
      loadPendingReleases(packageName ?? '')
    }

    // Reviews functionality
    const reviewForm = document.getElementById('review-form')
    const submitReviewBtn = document.getElementById('submit-review-btn')
    const reviewBodyInput = document.getElementById('review-body') as HTMLTextAreaElement | null
    const editReviewBtn = document.getElementById('edit-review-btn')
    const deleteReviewBtn = document.getElementById('delete-review-btn')
    const reviewEditForm = document.getElementById('review-edit-form')
    const submitEditBtn = document.getElementById('submit-edit-btn')
    const cancelEditBtn = document.getElementById('cancel-edit-btn')
    const editBodyInput = document.getElementById('edit-review-body') as HTMLTextAreaElement | null

    // Get rating from a star picker
    function getRatingFromPicker(name: string): number {
      const picker = document.querySelector(`.star-picker[data-name="${name}"]`)
      return parseInt(picker?.dataset.value ?? '0', 10)
    }

    // Get token from star button (reusing the same auth pattern)
    function getToken(): string | null {
      const starBtn = document.getElementById('star-btn')
      return starBtn?.dataset.token ?? null
    }

    submitReviewBtn?.addEventListener('click', async () => {
      if (!submitReviewBtn || !reviewBodyInput) return
      const rating = getRatingFromPicker('rating')
      if (rating < 1 || rating > 5) {
        alert('Please select a rating')
        return
      }

      submitReviewBtn.disabled = true
      const body = reviewBodyInput.value

      try {
        const res = await fetch('/api/reviews', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${getToken() ?? ''}`
          },
          body: JSON.stringify({ packageName, rating, body })
        })

        if (res.ok) {
          window.location.reload()
        } else {
          const data = await res.json()
          alert(data.error ?? 'Failed to submit review')
          submitReviewBtn.disabled = false
        }
      } catch {
        alert('Failed to submit review')
        submitReviewBtn.disabled = false
      }
    })

    editReviewBtn?.addEventListener('click', () => {
      if (reviewForm) reviewForm.style.display = 'none'
      if (reviewEditForm) reviewEditForm.classList.add('visible')
    })

    cancelEditBtn?.addEventListener('click', () => {
      if (reviewForm) reviewForm.style.display = 'block'
      if (reviewEditForm) reviewEditForm.classList.remove('visible')
    })

    submitEditBtn?.addEventListener('click', async () => {
      if (!submitEditBtn || !editBodyInput) return
      const rating = getRatingFromPicker('edit-rating')
      if (rating < 1 || rating > 5) {
        alert('Please select a rating')
        return
      }

      // Get the review ID from the user's existing review
      const userReviewId = window.location.pathname // We need to fetch this from the page data
      // For now, we'll reload the page after edit - a better implementation would pass the review ID via data attribute

      submitEditBtn.disabled = true
      const body = editBodyInput.value

      try {
        // We need the review ID - let's fetch it via an API call first
        const reviewRes = await fetch(`/api/reviews?package=${encodeURIComponent(packageName)}`, {
          headers: { 'Authorization': `Bearer ${getToken() ?? ''}` }
        })
        if (!reviewRes.ok) {
          alert('Failed to find your review')
          submitEditBtn.disabled = false
          return
        }
        const reviewData = await reviewRes.json()
        // Find the current user's review
        const token = getToken()
        let reviewId = null
        // Decode JWT to get user ID (simplified - in production use a proper JWT library)
        if (token) {
          try {
            const payload = JSON.parse(atob(token.split('.')[1]))
            const currentUserId = payload.sub
            const myReview = reviewData.reviews?.find((r: any) => r.user_id === currentUserId)
            if (myReview) reviewId = myReview.id
          } catch {}
        }

        if (!reviewId) {
          alert('Could not identify your review')
          submitEditBtn.disabled = false
          return
        }

        const res = await fetch(`/api/reviews/${reviewId}`, {
          method: 'PUT',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${getToken() ?? ''}`
          },
          body: JSON.stringify({ rating, body })
        })

        if (res.ok) {
          window.location.reload()
        } else {
          const data = await res.json()
          alert(data.error ?? 'Failed to update review')
          submitEditBtn.disabled = false
        }
      } catch {
        alert('Failed to update review')
        submitEditBtn.disabled = false
      }
    })

    deleteReviewBtn?.addEventListener('click', async () => {
      if (!confirm('Are you sure you want to delete your review?')) return

      try {
        // Find the review ID
        const reviewRes = await fetch(`/api/reviews?package=${encodeURIComponent(packageName)}`, {
          headers: { 'Authorization': `Bearer ${getToken() ?? ''}` }
        })
        if (!reviewRes.ok) {
          alert('Failed to find your review')
          return
        }
        const reviewData = await reviewRes.json()
        const token = getToken()
        let reviewId = null
        if (token) {
          try {
            const payload = JSON.parse(atob(token.split('.')[1]))
            const currentUserId = payload.sub
            const myReview = reviewData.reviews?.find((r: any) => r.user_id === currentUserId)
            if (myReview) reviewId = myReview.id
          } catch {}
        }

        if (!reviewId) {
          alert('Could not identify your review')
          return
        }

        const res = await fetch(`/api/reviews/${reviewId}`, {
          method: 'DELETE',
          headers: { 'Authorization': `Bearer ${getToken() ?? ''}` }
        })

        if (res.ok) {
          window.location.reload()
        } else {
          const data = await res.json()
          alert(data.error ?? 'Failed to delete review')
        }
      } catch {
        alert('Failed to delete review')
      }
    })
  </script>
</Base>
