            window.location.href = '/packages'
          } else {
            const data = await res.json().catch(() => ({}))
            deleteError.textContent = data?.error ?? 'Failed to delete organization.'
            deleteError.style.display = 'block'
            deleteSuccess.style.display = 'none'
          }
        } catch (e) {
          deleteError.textContent = 'An unexpected error occurred.'
          deleteError.style.display = 'block'
          deleteSuccess.style.display = 'none'
        }
      })
    }

    // --- Webhooks ---
    const webhooksError = document.getElementById('webhooks-error')!
    const webhooksSuccess = document.getElementById('webhooks-success')!
    const webhooksList = document.getElementById('webhooks-list')!
    const webhookUrlInput = document.getElementById('webhook-url-input') as HTMLInputElement
    const webhookEventsInput = document.getElementById('webhook-events-input') as HTMLInputElement
    const addWebhookBtn = document.getElementById('add-webhook-btn')!

    interface Webhook {
      id: string
      url: string
      events: string[]
      active: boolean
    }

    async function loadWebhooks() {
      const session = await getSession()
      if (!session) return
      webhooksList.innerHTML = '<p class="empty">Loading…</p>'
      try {
        const res = await fetch(`/api/${encodeURIComponent(slug)}/webhooks`, {
          headers: { 'Authorization': `Bearer ${session.access_token}` },
        })
        if (!res.ok) throw new Error('Failed to load')
        const webhooks: Webhook[] = await res.json()
        renderWebhooks(webhooks)
      } catch {
        webhooksList.innerHTML = '<p class="empty">Failed to load webhooks.</p>'
      }
    }

    function renderWebhooks(webhooks: Webhook[]) {
      if (webhooks.length === 0) {
        webhooksList.innerHTML = '<p class="empty">No webhooks configured.</p>'
        return
      }
      webhooksList.innerHTML = webhooks.map(w => `
        <div class="member-item" data-webhook-id="${w.id}">
          <div class="member-info">
            <span class="member-name">${escapeHtml(w.url)}</span>
            <span class="member-email">${w.events.join(', ')}</span>
          </div>
          <button class="btn btn-outline btn-sm delete-webhook-btn">Delete</button>
        </div>
      `).join('')

      webhooksList.querySelectorAll('.delete-webhook-btn').forEach(btn => {
        btn.addEventListener('click', async (e) => {
          const id = (e.target as HTMLElement).closest('.member-item')!.dataset.webhookId!
          const session = await getSession()
          if (!session) return
          ;(e.target as HTMLButtonElement).disabled = true
          try {
            const res = await fetch(`/api/${encodeURIComponent(slug)}/webhooks/${id}`, {
              method: 'DELETE',
              headers: { 'Authorization': `Bearer ${session.access_token}` },
            })
            if (res.ok) {
              showWebhookSuccess('Webhook deleted.')
              loadWebhooks()
            } else {
              const data = await res.json().catch(() => ({}))
              showWebhookError(data?.error ?? 'Failed to delete webhook.')
            }
          } catch {
            showWebhookError('Failed to delete webhook.')
          }
        })
      })
    }

    function showWebhookError(msg: string) {
      webhooksError.textContent = msg
      webhooksError.style.display = 'block'
      webhooksSuccess.style.display = 'none'
    }

    function showWebhookSuccess(msg: string) {
      webhooksSuccess.textContent = msg
      webhooksSuccess.style.display = 'block'
      webhooksError.style.display = 'none'
    }

    addWebhookBtn.addEventListener('click', async () => {
      const session = await getSession()
      if (!session) return
      const url = webhookUrlInput.value.trim()
      const eventsStr = webhookEventsInput.value.trim()
      if (!url || !eventsStr) {
        showWebhookError('URL and events are required.')
        return
      }
      const events = eventsStr.split(',').map(e => e.trim()).filter(Boolean)
      if (events.length === 0) {
        showWebhookError('At least one event is required.')
        return
      }
      addWebhookBtn.disabled = true
      webhooksError.style.display = 'none'
      webhooksSuccess.style.display = 'none'
      try {
        const res = await fetch(`/api/${encodeURIComponent(slug)}/webhooks`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${session.access_token}`,
          },
          body: JSON.stringify({ url, events }),
        })
        if (res.ok) {
          const data = await res.json()
          webhookUrlInput.value = ''
          webhookEventsInput.value = ''
          showWebhookSuccess(`Webhook created. Secret: ${data.secret} — save this, it won't be shown again.`)
          loadWebhooks()
        } else {
          const data = await res.json().catch(() => ({}))
          showWebhookError(data?.error ?? 'Failed to create webhook.')
        }
      } catch {
        showWebhookError('Failed to create webhook.')
      }
      addWebhookBtn.disabled = false
    })

    function escapeHtml(str: string) {
      return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;')
    }

    loadWebhooks()

    // --- Image Upload ---
    const imagesError = document.getElementById('images-error')!
    const imagesSuccess = document.getElementById('images-success')!

    async function processImage(file: File, type: 'avatar' | 'banner'): Promise<Blob> {
      const img = await createImageBitmap(file)
      const { width, height } = img

      const maxWidth = type === 'avatar' ? 400 : 1500
      const maxHeight = type === 'avatar' ? 400 : 500

      let targetWidth = width
      let targetHeight = height
      if (width > maxWidth || height > maxHeight) {
        const ratio = Math.min(maxWidth / width, maxHeight / height)
        targetWidth = Math.round(width * ratio)
        targetHeight = Math.round(height * ratio)
      }

      if (type === 'avatar') {
        const size = Math.min(targetWidth, targetHeight)
        const canvas = new OffscreenCanvas(size, size)
        const ctx = canvas.getContext('2d')!
        const sx = (width - size) / 2
        const sy = (height - size) / 2
        ctx.drawImage(img, sx, sy, size, size, 0, 0, size, size)
        return canvas.convertToBlob({ type: 'image/webp', quality: 0.85 })
      } else {
        const canvas = new OffscreenCanvas(targetWidth, targetHeight)
        const ctx = canvas.getContext('2d')!
        ctx.drawImage(img, 0, 0, targetWidth, targetHeight)
        return canvas.convertToBlob({ type: 'image/webp', quality: 0.85 })
      }
    }

    function showImageError(msg: string) {
      imagesError.textContent = msg
      imagesError.style.display = 'block'
      imagesSuccess.style.display = 'none'
    }

    function showImageSuccess(msg: string) {
      imagesSuccess.textContent = msg
      imagesSuccess.style.display = 'block'
      imagesError.style.display = 'none'
    }

    // Avatar upload
    const avatarUploadInput = document.getElementById('avatar-upload') as HTMLInputElement
    const uploadAvatarBtn = document.getElementById('upload-avatar-btn')!
    const removeAvatarBtn = document.getElementById('remove-avatar-btn')
    const avatarPreview = document.getElementById('avatar-preview') as HTMLImageElement
    const avatarPreviewFallback = document.getElementById('avatar-preview-fallback')

    uploadAvatarBtn.addEventListener('click', () => avatarUploadInput.click())

    avatarUploadInput.addEventListener('change', async () => {
      const file = avatarUploadInput.files?.[0]
      if (!file) return

      const session = await getSession()
      if (!session) return

      uploadAvatarBtn.disabled = true
      uploadAvatarBtn.innerHTML = '<span class="loading-spinner"></span>'
      imagesError.style.display = 'none'
      imagesSuccess.style.display = 'none'

      try {
        const processedBlob = await processImage(file, 'avatar')
        const formData = new FormData()
        formData.append('type', 'avatar')
        formData.append('file', processedBlob, 'avatar.webp')

        const res = await fetch(`/api/${encodeURIComponent(slug)}/images`, {
          method: 'PATCH',
          headers: {
            'Authorization': `Bearer ${session.access_token}`,
          },
          body: formData,
        })

        if (res.ok) {
          const data = await res.json()
          showImageSuccess('Avatar updated successfully.')

          // Update preview
          if (avatarPreview) {
            avatarPreview.src = data.avatar_url
            avatarPreview.style.display = 'block'
          }
          if (avatarPreviewFallback) {
            avatarPreviewFallback.style.display = 'none'
          }
          // Show remove button
          if (removeAvatarBtn) removeAvatarBtn.style.display = 'inline-flex'
        } else {
          const data = await res.json().catch(() => ({}))
          showImageError(data?.error ?? 'Failed to upload avatar.')
        }
      } catch {
        showImageError('An unexpected error occurred.')
      }

      uploadAvatarBtn.disabled = false
      uploadAvatarBtn.textContent = 'Upload new'
      avatarUploadInput.value = ''
    })

    if (removeAvatarBtn) {
      removeAvatarBtn.addEventListener('click', async () => {
        if (!confirm('Remove avatar? This cannot be undone.')) return

        const session = await getSession()
        if (!session) return

        removeAvatarBtn.disabled = true
        imagesError.style.display = 'none'
        imagesSuccess.style.display = 'none'

        try {
          const res = await fetch(`/api/${encodeURIComponent(slug)}/images`, {
            method: 'DELETE',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': `Bearer ${session.access_token}`,
            },
            body: JSON.stringify({ type: 'avatar' }),
          })

          if (res.ok) {
            showImageSuccess('Avatar removed.')
            if (avatarPreview) avatarPreview.style.display = 'none'
            if (avatarPreviewFallback) {
              avatarPreviewFallback.style.display = 'flex'
            }
            removeAvatarBtn.style.display = 'none'
          } else {
            const data = await res.json().catch(() => ({}))
            showImageError(data?.error ?? 'Failed to remove avatar.')
          }
        } catch {
          showImageError('An unexpected error occurred.')
        }

        removeAvatarBtn.disabled = false
      })
    }

    // Banner upload
    const bannerUploadInput = document.getElementById('banner-upload') as HTMLInputElement
    const uploadBannerBtn = document.getElementById('upload-banner-btn')!
    const removeBannerBtn = document.getElementById('remove-banner-btn')
    const bannerPreview = document.getElementById('banner-preview') as HTMLImageElement
    const bannerPreviewFallback = document.getElementById('banner-preview-fallback')

    uploadBannerBtn.addEventListener('click', () => bannerUploadInput.click())

    bannerUploadInput.addEventListener('change', async () => {
      const file = bannerUploadInput.files?.[0]
      if (!file) return

      const session = await getSession()
      if (!session) return

      uploadBannerBtn.disabled = true
      uploadBannerBtn.innerHTML = '<span class="loading-spinner"></span>'
      imagesError.style.display = 'none'
      imagesSuccess.style.display = 'none'

      try {
        const processedBlob = await processImage(file, 'banner')
        const formData = new FormData()
        formData.append('type', 'banner')
        formData.append('file', processedBlob, 'banner.webp')

        const res = await fetch(`/api/${encodeURIComponent(slug)}/images`, {
          method: 'PATCH',
          headers: {
            'Authorization': `Bearer ${session.access_token}`,
          },
          body: formData,
        })

        if (res.ok) {
          const data = await res.json()
          showImageSuccess('Banner updated successfully.')
          if (bannerPreview) {
            bannerPreview.src = data.banner_url
            bannerPreview.style.display = 'block'
          }
          if (bannerPreviewFallback) {
            bannerPreviewFallback.style.display = 'none'
          }
          if (removeBannerBtn) removeBannerBtn.style.display = 'inline-flex'
        } else {
          const data = await res.json().catch(() => ({}))
          showImageError(data?.error ?? 'Failed to upload banner.')
        }
      } catch {
        showImageError('An unexpected error occurred.')
      }

      uploadBannerBtn.disabled = false
      uploadBannerBtn.textContent = 'Upload new'
      bannerUploadInput.value = ''
    })

    if (removeBannerBtn) {
      removeBannerBtn.addEventListener('click', async () => {
        if (!confirm('Remove banner? This cannot be undone.')) return

        const session = await getSession()
        if (!session) return

        removeBannerBtn.disabled = true
        imagesError.style.display = 'none'
        imagesSuccess.style.display = 'none'

        try {
          const res = await fetch(`/api/${encodeURIComponent(slug)}/images`, {
            method: 'DELETE',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': `Bearer ${session.access_token}`,
            },
            body: JSON.stringify({ type: 'banner' }),
          })

          if (res.ok) {
            showImageSuccess('Banner removed.')
            if (bannerPreview) bannerPreview.style.display = 'none'
            if (bannerPreviewFallback) {
              bannerPreviewFallback.style.display = 'flex'
            }
            removeBannerBtn.style.display = 'none'
          } else {
            const data = await res.json().catch(() => ({}))
            showImageError(data?.error ?? 'Failed to remove banner.')
          }
        } catch {
          showImageError('An unexpected error occurred.')
        }

        removeBannerBtn.disabled = false
      })
    }
  </script>
