---
import Base from '../../layouts/Base.astro'
import { listTags } from '../../lib/db.js'

const tags = await listTags().catch(() => [])
---
<Base title="Tags">
  <style>
    .page-header {
      margin-bottom: 2rem;
    }

    .page-header h1 {
      font-family: var(--font-mono);
      font-size: 1.25rem;
      font-weight: 600;
      letter-spacing: -0.02em;
    }

    .page-header p {
      font-size: 0.875rem;
      color: var(--muted);
      margin-top: 0.5rem;
    }

    .tags-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
    }

    .tag-chip {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.4rem 0.85rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 6px;
      text-decoration: none;
      font-family: var(--font-mono);
      font-size: 0.875rem;
      color: var(--text);
      transition: border-color 0.15s;
    }

    .tag-chip:hover {
      border-color: var(--accent);
      opacity: 1;
    }

    .tag-count {
      font-size: 0.75rem;
      color: var(--muted);
    }

    .empty {
      font-family: var(--font-mono);
      font-size: 0.875rem;
      color: var(--muted);
      padding: 3rem 0;
    }
  </style>

  <div class="page-header">
    <h1>tags</h1>
    <p>Browse packages by topic</p>
  </div>

  {tags.length === 0
    ? <p class="empty">no tags yet.</p>
    : <div class="tags-grid">
        {tags.map(tag => (
          <a class="tag-chip" href={`/tags/${encodeURIComponent(tag.name)}`}>
            <span>{tag.name}</span>
            <span class="tag-count">{tag.package_count}</span>
          </a>
        ))}
      </div>
  }
</Base>
